# --- Datastore (Postgres + pgvector, e.g. Supabase / Neon) ---
DATABASE_URL=postgres://user:pass@host:5432/db
STORE_BACKEND=file            # "file" (dev, no DB) or "postgres"
STORE_FILE_PATH=.state/store.json

# --- LLM providers (only those you use need a key) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=               # used for GPT-5.5 gate + embeddings
GOOGLE_API_KEY=               # Gemini
DEEPSEEK_API_KEY=             # optional, cheap triage/notes

# --- Transcripts ---
SUPADATA_API_KEY=

# --- Publishing ---
GITHUB_TOKEN=                 # fine-grained PAT: contents:rw on kenashe/kenashe
GITHUB_REPO=kenashe/kenashe
GIT_BRANCH=master
VERCEL_DEPLOY_HOOK=

# --- Notifications (daily digest + errors) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Run shape ---
DAILY_FLAGSHIPS=3
DAILY_NOTES_MAX=7
DEDUP_SIMILARITY=0.82         # cosine >= this vs covered memory => skip as dupe
CLUSTER_SIMILARITY=0.78       # cosine >= this groups items into one story
TOPIC_COOLDOWN_DAYS=14
