---
interface Props {
  date: Date;
  format?: 'long' | 'short';
}

const { date, format = 'long' } = Astro.props;
const iso = date.toISOString();
const display = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: format === 'long' ? 'long' : 'short',
  day: 'numeric',
});
---

<time datetime={iso}>{display}</time>
