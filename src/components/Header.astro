---
import { NAV } from '../consts';

const path = Astro.url.pathname;
const isCurrent = (href: string) => {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
};
---

<header class="site-header" data-scrolled="false">
  <div class="inner">
    <a href="/" class="wordmark" aria-label="Ken Ashe — home">
      <span class="brace" aria-hidden="true">{'{'}</span>
      <span class="name">ken ashe</span>
      <span class="brace" aria-hidden="true">{'}'}</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          NAV.map(({ label, href }) => {
            const external = /^https?:\/\//.test(href);
            return (
              <li>
                <a
                  href={href}
                  aria-current={!external && isCurrent(href) ? 'page' : undefined}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener' : undefined}
                >
                  {label}
                  {external && (
                    <span class="ext" aria-hidden="true">
                      ↗
                    </span>
                  )}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--bg);
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease;
  }
  .site-header[data-scrolled='true'] {
    border-bottom-color: var(--border);
  }
  .inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 1.125rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .wordmark {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    margin-right: auto;
    letter-spacing: 0.01em;
    display: inline-flex;
    align-items: baseline;
    gap: 0.25em;
  }
  .wordmark .brace {
    color: var(--accent);
  }
  .wordmark:hover {
    color: var(--accent);
  }
  nav ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  nav a {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  nav a:hover {
    color: var(--accent);
  }
  nav a[aria-current='page'] {
    color: var(--fg);
  }
  nav a .ext {
    display: inline-block;
    margin-left: 0.15em;
    font-size: 0.75em;
    opacity: 0.7;
  }
  @media (max-width: 520px) {
    .inner {
      padding: 1rem 1.25rem;
      gap: 1rem;
    }
    nav ul {
      gap: 1rem;
    }
    nav a {
      font-size: 0.875rem;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('.site-header');
  if (header) {
    const update = () => {
      header.setAttribute('data-scrolled', window.scrollY > 4 ? 'true' : 'false');
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
