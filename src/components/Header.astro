---
import { AUTHOR, NAV } from '../consts';

const path = Astro.url.pathname;
const isCurrent = (href: string) => {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
};
---

<header class="site-header">
  <div class="inner">
    <a href="/" class="wordmark" aria-label={`${AUTHOR} — home`}>
      {AUTHOR}
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          NAV.map(({ label, href }) => {
            const external = /^https?:\/\//.test(href);
            return (
              <li>
                <a
                  href={href}
                  aria-current={!external && isCurrent(href) ? 'page' : undefined}
                  target={external ? '_blank' : undefined}
                  rel={external ? 'noopener' : undefined}
                >
                  {label}
                  {external && (
                    <span class="ext" aria-hidden="true">
                      ↗
                    </span>
                  )}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
  }
  .inner {
    max-width: 56rem;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--font-sans);
  }
  .wordmark {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-decoration: none;
    margin-right: auto;
  }
  .wordmark:hover {
    color: var(--fg);
  }
  nav ul {
    display: flex;
    gap: 1.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  nav a {
    font-size: 0.9375rem;
    color: var(--muted);
    text-decoration: none;
  }
  nav a:hover {
    color: var(--fg);
  }
  nav a[aria-current='page'] {
    color: var(--fg);
  }
  nav a .ext {
    display: inline-block;
    margin-left: 0.15em;
    font-size: 0.75em;
    opacity: 0.7;
  }
  @media (max-width: 480px) {
    .inner {
      gap: 1rem;
      padding: 1rem 1.25rem;
    }
    nav ul {
      gap: 1rem;
    }
  }
</style>
