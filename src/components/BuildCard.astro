---
import type { Project } from '../data/builds';

interface Props {
  project: Project;
}

const { project: p } = Astro.props;
---

<li class={`receipt receipt-${p.status.toLowerCase()}`}>
  <div class="receipt-head">
    <h3 class="receipt-title">{p.title}</h3>
    <span class={`badge badge-${p.status.toLowerCase()}`}>
      <span class="badge-dot" aria-hidden="true" />
      {p.status}
    </span>
  </div>
  <p class="receipt-dek">{p.dek}</p>
  <ul class="receipt-stack" aria-label="Stack">
    {p.stack.map((s) => <li>{s}</li>)}
  </ul>
  <footer class="receipt-foot">
    {
      p.footer ? (
        p.footer.map((item, i) => (
          <>
            {i > 0 && (
              <span class="receipt-meta-sep" aria-hidden="true">
                ·
              </span>
            )}
            <span class="receipt-meta">{item}</span>
          </>
        ))
      ) : (
        <>
          <span class="receipt-meta">
            <span class="receipt-meta-key">Shipped</span> {p.shippedAt}
          </span>
          {p.metric && (
            <>
              <span class="receipt-meta-sep" aria-hidden="true">
                ·
              </span>
              <span class="receipt-meta">{p.metric}</span>
            </>
          )}
        </>
      )
    }
  </footer>
</li>

<style>
  .receipt {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.5rem 1.5rem 1.25rem;
    transition:
      border-color 200ms ease,
      transform 200ms ease;
  }
  .receipt:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .receipt-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.65rem;
  }
  .receipt-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--fg);
    margin: 0;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    white-space: nowrap;
    background-color: var(--bg);
  }
  .badge-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background-color: currentColor;
  }
  .badge-live {
    color: var(--accent-2);
    border-color: color-mix(in oklab, var(--accent-2) 35%, var(--border));
  }
  .badge-live .badge-dot {
    background-color: var(--accent-2);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent-2) 18%, transparent);
  }
  .badge-shipped {
    color: #94a3b8;
    border-color: rgb(100 116 139 / 0.2);
    background-color: rgb(100 116 139 / 0.1);
  }
  .badge-shipped .badge-dot {
    background-color: #64748b;
  }
  .receipt-dek {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--fg);
    margin: 0 0 1.25rem;
    max-width: 44rem;
  }
  .receipt-stack {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .receipt-stack li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.25rem 0.55rem;
    font-variant-numeric: tabular-nums;
  }
  .receipt-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .receipt-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg);
    font-variant-numeric: tabular-nums;
  }
  .receipt-meta-key {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-right: 0.4rem;
  }
  .receipt-meta-sep {
    color: var(--border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
</style>
