---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import JsonLd from '../components/JsonLd.astro';
import { readingTime } from '../utils/reading-time';
import { SITE_URL, AUTHOR, NEWSLETTER_URL } from '../consts';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  image?: { src: ImageMetadata; alt: string };
  tags: string[];
  draft: boolean;
  body: string;
}

const { id, title, description, pubDate, updatedDate, image, tags, draft, body } = Astro.props;
const { minutes } = readingTime(body ?? '');
const url = new URL(`/blog/${id}/`, SITE_URL).toString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: AUTHOR, url: SITE_URL },
  publisher: { '@type': 'Person', name: AUTHOR, url: SITE_URL },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  url,
  keywords: tags?.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'The Lab', item: `${SITE_URL}/blog/` },
    { '@type': 'ListItem', position: 3, name: title, item: url },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: updatedDate?.toISOString(),
    tags,
  }}
>
  <Fragment slot="jsonld">
    <JsonLd data={[articleSchema, breadcrumbSchema]} />
  </Fragment>

  <article class="post">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/blog/">
        <span aria-hidden="true">←</span> The Lab
      </a>
    </nav>

    {
      image && (
        <figure class="hero-image">
          <Image
            src={image.src}
            alt={image.alt}
            widths={[480, 768, 1200, 1600]}
            sizes="(min-width: 720px) 640px, 100vw"
          />
        </figure>
      )
    }

    <header class="post-header">
      {draft && <p class="draft-badge">Draft</p>}
      <h1>{title}</h1>
      {
        tags?.length > 0 && (
          <ul class="post-tags" aria-label="Tags">
            {tags.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
        )
      }
      <p class="meta">
        <FormattedDate date={pubDate} />
        <span aria-hidden="true"> · </span>
        <span>{minutes} min read</span>
        {
          updatedDate && (
            <>
              <span aria-hidden="true"> · </span>
              <span>
                Updated <FormattedDate date={updatedDate} format="short" />
              </span>
            </>
          )
        }
      </p>
      {description && <p class="lead">{description}</p>}
    </header>

    <div class="prose">
      <slot />
    </div>

    <aside class="newsletter-cta">
      <p class="cta-label" aria-hidden="true">// newsletter</p>
      <p class="cta-body">For long-form essays in my voice, subscribe to my newsletter.</p>
      <a class="cta-link" href={NEWSLETTER_URL} target="_blank" rel="noopener">
        Subscribe
        <span aria-hidden="true">→</span>
      </a>
    </aside>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 40rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }

  .crumbs {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin: 0 0 2.5rem;
  }
  .crumbs a {
    color: inherit;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .crumbs a:hover {
    color: var(--accent);
  }

  .hero-image {
    margin: 0 0 2.5rem;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
  }
  .hero-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-header {
    margin-bottom: 3rem;
  }
  .draft-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    border: 1px solid color-mix(in oklab, var(--accent) 35%, var(--border));
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    margin: 0 0 1.25rem;
  }
  .post-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 1.25rem;
    color: var(--fg);
  }
  .post-tags {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .post-tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.02em;
    color: var(--muted);
    background-color: var(--surface);
    border: 1px solid var(--border);
    padding: 0.22rem 0.5rem;
    border-radius: 4px;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    margin: 0 0 1.5rem;
  }
  .lead {
    font-family: var(--font-sans);
    font-size: 1.1875rem;
    line-height: 1.5;
    color: var(--fg);
    margin: 0;
    max-width: 36rem;
  }

  .newsletter-cta {
    margin: 4rem 0 0;
    padding: 1.75rem 1.75rem 1.5rem;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
  }
  .cta-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0;
  }
  .cta-body {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--fg);
    margin: 0;
  }
  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--bg);
    background-color: var(--accent);
    border: 1px solid var(--accent);
    text-decoration: none;
    padding: 0.55rem 1rem;
    border-radius: 4px;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      border-color 150ms ease;
  }
  .cta-link:hover {
    background-color: var(--fg);
    border-color: var(--fg);
    color: var(--bg);
  }
</style>
