---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import JsonLd from '../components/JsonLd.astro';
import { readingTime } from '../utils/reading-time';
import { SITE_URL, AUTHOR } from '../consts';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  image?: { src: ImageMetadata; alt: string };
  tags: string[];
  draft: boolean;
  body: string;
}

const { id, title, description, pubDate, updatedDate, image, tags, draft, body } = Astro.props;
const { minutes } = readingTime(body ?? '');
const url = new URL(`/blog/${id}/`, SITE_URL).toString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: AUTHOR, url: SITE_URL },
  publisher: { '@type': 'Person', name: AUTHOR, url: SITE_URL },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  url,
  keywords: tags?.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'AI Blog', item: `${SITE_URL}/blog/` },
    { '@type': 'ListItem', position: 3, name: title, item: url },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  article={{
    publishedTime: pubDate.toISOString(),
    modifiedTime: updatedDate?.toISOString(),
    tags,
  }}
>
  <Fragment slot="jsonld">
    <JsonLd data={[articleSchema, breadcrumbSchema]} />
  </Fragment>

  <article class="post">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/blog/">AI Blog</a>
    </nav>

    {
      image && (
        <figure class="hero-image">
          <Image
            src={image.src}
            alt={image.alt}
            widths={[480, 768, 1200, 1600]}
            sizes="(min-width: 720px) 640px, 100vw"
          />
        </figure>
      )
    }

    <header class="post-header">
      {draft && <p class="draft-badge">Draft</p>}
      <h1>{title}</h1>
      {
        tags?.length > 0 && (
          <ul class="post-tags" aria-label="Tags">
            {tags.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
        )
      }
      <p class="meta">
        <FormattedDate date={pubDate} />
        <span aria-hidden="true"> · </span>
        <span>{minutes} min read</span>
        {
          updatedDate && (
            <>
              <span aria-hidden="true"> · </span>
              <span>
                Updated <FormattedDate date={updatedDate} format="short" />
              </span>
            </>
          )
        }
      </p>
      {description && <p class="lead">{description}</p>}
    </header>

    <div class="prose">
      <slot />
    </div>

    <aside class="newsletter-cta">
      <p class="cta-label">Newsletter</p>
      <p class="cta-body">For long-form essays in my voice, subscribe to my newsletter.</p>
      <a href="https://newsletter.kenashe.ai" target="_blank" rel="noopener">newsletter.kenashe.ai</a>
    </aside>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 40rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 0;
  }

  .crumbs {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }
  .crumbs a {
    color: inherit;
    text-decoration: none;
  }
  .crumbs a:hover {
    color: var(--fg);
  }

  .post-header {
    margin-bottom: 2.5rem;
  }
  .draft-badge {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    border: 1px solid var(--rule);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    margin: 0 0 1rem;
  }
  .post-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 1rem;
  }
  .meta {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0 0 1.5rem;
  }
  .lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1875rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }
  .hero-image {
    margin: 0 0 2.5rem;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--subtle);
    border-radius: 2px;
  }
  .hero-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-tags {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    font-family: var(--font-sans);
  }
  .post-tags li {
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: var(--muted);
    border: 1px solid var(--rule);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }

  .newsletter-cta {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--rule);
  }
  .cta-label {
    font-family: Inter, sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin: 0 0 0.75rem;
  }
  .cta-body {
    font-family: Newsreader, serif;
    font-size: 1.0625rem;
    line-height: 1.6;
    margin: 0 0 0.75rem;
    color: var(--fg);
  }
  .newsletter-cta a {
    font-family: Inter, sans-serif;
    font-size: 0.9375rem;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 150ms;
  }
  .newsletter-cta a:hover {
    border-bottom-color: var(--accent);
  }
</style>
