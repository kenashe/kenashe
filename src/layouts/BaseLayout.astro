---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import Analytics from '@vercel/analytics/astro';
import { breadcrumbList, type Crumb } from '../utils/breadcrumbs';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  ogTitle?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
  };
  // Optional breadcrumb trail; emits a BreadcrumbList JSON-LD when provided.
  breadcrumbs?: Crumb[];
}

const { title, description, image, ogType, ogTitle, ogImageWidth, ogImageHeight, article, breadcrumbs } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      ogType={ogType}
      ogTitle={ogTitle}
      ogImageWidth={ogImageWidth}
      ogImageHeight={ogImageHeight}
      article={article}
    >
      {breadcrumbs && breadcrumbs.length > 0 && (
        <JsonLd slot="jsonld" data={breadcrumbList(breadcrumbs)} />
      )}
      <slot name="jsonld" slot="jsonld" />
    </BaseHead>
    <meta name="google-site-verification" content="t06zUUzZYjF_GRzSlyePRz_W7YTUjVy_ZfQvlWON7DA" />
    <Analytics />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
