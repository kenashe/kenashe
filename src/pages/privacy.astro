---
import BaseLayout from '../layouts/BaseLayout.astro';

const description =
  'How KenAshe.ai handles your information: what the contact form and analytics collect, and what I never do with your data.';
const updated = 'June 25, 2026';
---

<BaseLayout
  title="Privacy"
  description={description}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Privacy', path: '/privacy/' },
  ]}
>
  <article class="legal">
    <header class="legal-header">
      <p class="page-mark" aria-hidden="true">// privacy</p>
      <h1>Privacy</h1>
      <p class="updated">Last updated {updated}</p>
    </header>

    <div class="prose">
      <p>
        This site is a personal publication and build log. It is intentionally simple, and it
        collects very little. Here is exactly what happens with your information.
      </p>

      <h2>What I collect</h2>
      <ul>
        <li>
          <strong>Contact form.</strong> When you use the contact form, I receive what you enter:
          your name, email, inquiry type, and anything you write in the optional organization,
          topic, deadline, and message fields. The form is processed by Web3Forms, a third-party
          service that passes your submission to me by email. I use it only to read and reply to
          your message.
        </li>
        <li>
          <strong>Analytics.</strong> This site uses Vercel Web Analytics, which reports
          aggregate, anonymized traffic such as page views, referrers, approximate country, and
          device type. It does not use cookies and does not identify you personally.
        </li>
        <li>
          <strong>Hosting logs.</strong> The site is hosted on Vercel. Like most hosts, Vercel may
          keep short-lived server logs (for example, IP address and browser type) for security and
          reliability.
        </li>
      </ul>

      <h2>What I do not do</h2>
      <ul>
        <li>I do not sell, rent, or trade your information.</li>
        <li>I do not run advertising or cross-site tracking pixels.</li>
        <li>There are no user accounts and no login.</li>
        <li>This site does not set tracking cookies.</li>
      </ul>

      <h2>Third parties</h2>
      <p>
        Two services help run the site, each with its own privacy policy:
        <a href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener">Vercel</a>
        (hosting and privacy-friendly analytics) and
        <a href="https://web3forms.com/privacy-policy" target="_blank" rel="noopener">Web3Forms</a>
        (contact-form delivery).
      </p>

      <h2>Keeping and removing your data</h2>
      <p>
        I keep contact emails for as long as I need them to handle your inquiry and any reasonable
        follow-up. If you want to know what I hold, or you want it deleted, email me at
        <a href="mailto:hello@kenashe.ai">hello@kenashe.ai</a> and I will take care of it. If you
        are somewhere with data-protection rights (such as the EU, UK, or California), email me and
        I will honor reasonable requests.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about privacy: <a href="mailto:hello@kenashe.ai">hello@kenashe.ai</a>.
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .legal {
    max-width: 44rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .legal-header {
    margin-bottom: 2.5rem;
  }
  .page-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  .legal-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0 0 1rem;
    color: var(--fg);
  }
  .updated {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
  }
</style>
