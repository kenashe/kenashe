---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="That page doesn't exist (or it moved).">
  <div class="page">
    <p class="mark" aria-hidden="true">// 404</p>
    <h1>Page not found</h1>
    <p class="lede">
      That link points to something that moved, shipped, or never existed. The Lab
      publishes fast — sometimes a URL gets renamed out from under a link.
    </p>
    <p class="actions">
      <a href="/"><span aria-hidden="true">←</span> Home</a>
      <a href="/blog/">The Lab</a>
    </p>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 40rem;
    margin: 0 auto;
    padding: 7rem 1.5rem 0;
    min-height: 50vh;
  }
  .mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0 0 1.25rem;
    color: var(--fg);
  }
  .lede {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 0 0 2rem;
    max-width: 32rem;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
  }
  .actions a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.2rem;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .actions a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
