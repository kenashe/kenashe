---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { personKenAshe } from '../../data/schema';

const headline =
  'KenAshe.ai Launches as a Public Build Log for Practical AI Projects and Autonomous Blogging';
const description =
  'Personal site from AI operator Ken Ashe documents AI builds, automation experiments, and the process of building with AI in public';

const releaseSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'NewsArticle',
      '@id': 'https://kenashe.ai/news/site-launch/#article',
      headline:
        'KenAshe.ai Launches as a Public Build Log for Practical AI Projects and Autonomous Blogging',
      url: 'https://kenashe.ai/news/site-launch/',
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': 'https://kenashe.ai/news/site-launch/',
      },
      datePublished: '2026-06-24T09:00:00-04:00',
      dateModified: '2026-06-24T09:00:00-04:00',
      image: ['https://kenashe.ai/og/kenashe-ai-site-launch.png'],
      author: { '@id': 'https://kenashe.ai/#ken-ashe' },
      publisher: { '@id': 'https://kenashe.ai/#ken-ashe' },
      isPartOf: { '@id': 'https://kenashe.ai/#website' },
      about: [
        { '@id': 'https://kenashe.ai/#ken-ashe' },
        { '@id': 'https://kenashe.ai/#website' },
      ],
      mentions: [
        { '@id': 'https://kenashe.ai/#building' },
        { '@id': 'https://kenashe.ai/#lab' },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': 'https://kenashe.ai/#website',
      name: 'KenAshe.ai',
      url: 'https://kenashe.ai/',
      sameAs: ['https://www.linkedin.com/company/kenashe-ai'],
      description:
        'Personal publication and public AI build log from Ken Ashe, documenting practical AI projects, autonomous blogging, automation experiments, and building with AI in public.',
      creator: { '@id': 'https://kenashe.ai/#ken-ashe' },
      publisher: { '@id': 'https://kenashe.ai/#ken-ashe' },
      mainEntity: { '@id': 'https://kenashe.ai/#ken-ashe' },
      inLanguage: 'en-US',
    },
    {
      '@type': 'CollectionPage',
      '@id': 'https://kenashe.ai/#building',
      name: 'Building',
      url: 'https://kenashe.ai/building/',
      description: 'A public project log tracking live and completed AI builds from Ken Ashe.',
      isPartOf: { '@id': 'https://kenashe.ai/#website' },
      creator: { '@id': 'https://kenashe.ai/#ken-ashe' },
      inLanguage: 'en-US',
    },
    {
      '@type': 'Blog',
      '@id': 'https://kenashe.ai/#lab',
      name: 'The Lab',
      url: 'https://kenashe.ai/blog/',
      description:
        'An autonomous AI blog covering practical AI workflows, agents, prompt engineering, AI coding tools, SEO, and marketing automation.',
      isPartOf: { '@id': 'https://kenashe.ai/#website' },
      creator: { '@id': 'https://kenashe.ai/#ken-ashe' },
      publisher: { '@id': 'https://kenashe.ai/#ken-ashe' },
      inLanguage: 'en-US',
    },
    personKenAshe,
  ],
};
---

<BaseLayout
  title={headline}
  description={description}
  ogType="article"
  ogTitle={headline}
  image="/og/kenashe-ai-site-launch.png"
  ogImageWidth={1200}
  ogImageHeight={630}
>
  <JsonLd slot="jsonld" data={releaseSchema} />

  <article class="post release">
    <p class="release-eyebrow">FOR IMMEDIATE RELEASE</p>

    <header class="post-header">
      <h1>{headline}</h1>
      <p class="lead">{description}</p>
    </header>

    <div class="prose">
      <p>
        <strong>NEW JERSEY — June 24, 2026 —</strong> Ken Ashe today launched
        <a href="https://kenashe.ai/">KenAshe.ai</a>, a personal website documenting his work
        building with AI in public. The site is a running record of the AI projects he ships,
        the automation systems he runs, and the AI-assisted development experiments he tests,
        including an autonomous blog that publishes field notes on AI, marketing automation, and
        digital operations.
      </p>

      <p>
        KenAshe.ai is built for founders, marketers, operators, and builders who want to see how
        AI gets used to ship real projects, not just discussed. Rather than focusing only on
        commentary or industry news, the site documents applied work: autonomous content
        workflows, AI agents, SEO experiments, coding assistants, and marketing automation.
      </p>

      <p>
        "AI is moving too quickly for theory alone," said Ken Ashe, founder of KenAshe.ai. "The
        point of this site is to show the work: what I'm building, what shipped, what broke, and
        what other operators can learn from it."
      </p>

      <p>
        The site's <a href="https://kenashe.ai/building/">Building</a> section is a public project
        log tracking live and completed AI builds, with examples spanning AI-assisted website
        builds, autonomous publishing workflows, a geo-targeted affiliate site, email automation,
        and a personal assistant chatbot. Each entry documents how an idea moved from concept to
        something that runs.
      </p>

      <p>
        The site also houses <a href="https://kenashe.ai/blog/">The Lab</a>, an autonomous AI blog
        covering practical AI workflows, agents, prompt engineering, AI coding tools, SEO, and
        marketing automation. The blog runs on an automated pipeline that researches current AI
        developments, drafts posts, applies a quality review step, and publishes selected articles.
      </p>

      <p>
        KenAshe.ai reflects a broader shift in how individuals and small teams work with AI. As the
        tools get more capable, operators no longer need large teams or perfect conditions to test
        an idea. They can use AI at the application layer to automate recurring work and stand up
        new digital projects quickly.
      </p>

      <p>
        "The opportunity isn't talking about AI. It's learning to use it to build useful things,"
        Ashe added. "KenAshe.ai is where I'm documenting that process in public."
      </p>

      <p>Readers can visit KenAshe.ai to explore the project log and read new posts from The Lab.</p>

      <h2>About Ken Ashe</h2>

      <p>
        Ken Ashe is a digital marketer, CPA, PMP, and AI operator who builds with AI in public.
        KenAshe.ai documents his real builds and experiments across practical AI workflows, agents,
        autonomous content systems, marketing automation, and AI-assisted development to help
        marketers, founders, operators, and non-engineer builders see how AI can be used to create
        useful digital systems.
      </p>

      <h2>Media Contact</h2>

      <p>
        Ken Ashe<br />
        Founder, KenAshe.ai<br />
        Website: <a href="https://kenashe.ai/">https://kenashe.ai/</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 40rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .release-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin: 0 0 2.5rem;
  }
  .post-header {
    margin-bottom: 3rem;
  }
  .post-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 1.25rem;
    color: var(--fg);
  }
  .lead {
    font-family: var(--font-sans);
    font-size: 1.1875rem;
    line-height: 1.5;
    color: var(--fg);
    margin: 0;
    max-width: 36rem;
  }
</style>
