---
// Phase 1 - PR1: §3 visual-system PREVIEW (spec v2.2 §3).
// Self-contained on purpose: this page does NOT import BaseLayout or global.css,
// so it previews the new bright ice/navy "AI lab" system in isolation without
// touching the current (warm-dark) live site. noindex. Throwaway reference -
// once the direction is approved, these tokens get lifted into global.css and
// rolled out page by page, and this preview route is removed.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>KenAshe.ai - Visual System Preview (Phase 1)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        /* §3 palette (brand card) */
        --navy: #011338;
        --dark-blue: #183473;
        --core-blue: #2e74c9;
        --bright-blue: #5795f5;
        --teal-blue: #0871ac;
        --pale-blue: #c7dafb;
        --ice: #f5f7fc;
        --white: #fdfdfd;
        /* derived */
        --ink: var(--navy);
        --body: #42526e; /* slate-blue secondary text */
        --line: #dbe4f5;
        --grad: linear-gradient(135deg, #0871ac 0%, #2e74c9 45%, #5795f5 76%, #183473 100%);
        --shadow-sm: 0 1px 2px rgba(1, 19, 56, 0.06);
        --shadow: 0 10px 30px rgba(1, 19, 56, 0.08);
        --r: 14px;
        --font-display: 'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif;
        --font-sans: 'Inter', ui-sans-serif, system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        background: var(--ice);
        color: var(--body);
        font-family: var(--font-sans);
        font-size: 1.0625rem;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      h1, h2, h3, h4 { font-family: var(--font-display); color: var(--ink); letter-spacing: -0.02em; line-height: 1.1; margin: 0; }
      a { color: var(--core-blue); }
      code { font-family: var(--font-mono); font-size: 0.85em; }
      .wrap { max-width: 1080px; margin: 0 auto; padding: 0 1.5rem; }

      /* Preview banner */
      .preview-note {
        background: var(--navy);
        color: var(--pale-blue);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        padding: 0.7rem 1.5rem;
        text-align: center;
      }
      .preview-note strong { color: var(--white); }

      /* Diagonal/geometric motif divider */
      .motif-bar { height: 6px; background: var(--grad); }
      section { padding: 3.5rem 0; border-bottom: 1px solid var(--line); }
      .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--teal-blue);
        margin: 0 0 0.9rem;
      }
      section > .wrap > h2 { font-size: 1.75rem; margin-bottom: 1.5rem; }

      /* HERO */
      .hero {
        background:
          radial-gradient(900px 400px at 85% -10%, var(--pale-blue), transparent 60%),
          var(--white);
        padding: 4.5rem 0 4rem;
        position: relative;
        overflow: hidden;
      }
      .hero::after {
        content: '';
        position: absolute;
        right: -120px; bottom: -120px;
        width: 360px; height: 360px;
        background: var(--grad);
        opacity: 0.12;
        transform: rotate(18deg);
        border-radius: 48px;
      }
      .hero h1 { font-size: clamp(2.8rem, 6vw, 4.75rem); font-weight: 800; }
      .hero .tagline { font-size: clamp(1.25rem, 2.2vw, 1.6rem); font-weight: 600; color: var(--core-blue); margin: 0.5rem 0 1rem; font-family: var(--font-display); }
      .hero .subhead { max-width: 40rem; font-size: 1.125rem; margin: 0 0 1.75rem; }
      .trust { font-family: var(--font-mono); font-size: 0.8rem; color: var(--dark-blue); letter-spacing: 0.02em; margin-top: 1.5rem; }

      /* Buttons */
      .btn { display: inline-flex; align-items: center; gap: 0.45rem; font-family: var(--font-sans); font-weight: 600; font-size: 0.95rem; padding: 0.7rem 1.3rem; border-radius: 10px; text-decoration: none; border: 1px solid transparent; cursor: pointer; }
      .btn-primary { background: var(--grad); color: var(--white); box-shadow: var(--shadow-sm); }
      .btn-ghost { background: var(--white); color: var(--dark-blue); border-color: var(--line); }
      .btn-row { display: flex; flex-wrap: wrap; gap: 0.75rem; }

      /* Palette */
      .swatches { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem; }
      .swatch { border: 1px solid var(--line); border-radius: 10px; overflow: hidden; background: var(--white); box-shadow: var(--shadow-sm); }
      .swatch .chip { height: 76px; }
      .swatch .meta { padding: 0.55rem 0.7rem; font-family: var(--font-mono); font-size: 0.72rem; color: var(--body); }
      .swatch .meta b { display: block; color: var(--ink); font-family: var(--font-sans); font-size: 0.8rem; }

      /* Type scale */
      .type-row { margin: 0 0 1rem; }
      .type-row span { font-family: var(--font-mono); font-size: 0.7rem; color: var(--teal-blue); display: block; margin-bottom: 0.2rem; }

      /* Status badges */
      .badges { display: flex; flex-wrap: wrap; gap: 0.6rem; }
      .badge { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; padding: 0.3rem 0.65rem; border-radius: 999px; border: 1px solid; }
      .badge.inprogress { color: #9a5b00; background: #fff4e0; border-color: #f1d6a8; }
      .badge.live { color: #0e7a37; background: #e6f6ec; border-color: #b7e3c6; }
      .badge.shipped { color: var(--core-blue); background: var(--pale-blue); border-color: #a9c6f5; }
      .badge.archived { color: #5a6b86; background: #eef1f7; border-color: #d8dfec; }

      /* Cards */
      .cards { display: grid; gap: 1.25rem; }
      .grid-2 { grid-template-columns: 1fr; }
      @media (min-width: 760px) { .grid-2 { grid-template-columns: 1fr 1fr; } }

      .card { background: var(--white); border: 1px solid var(--line); border-radius: var(--r); box-shadow: var(--shadow); position: relative; overflow: hidden; }
      .card::before { content: ''; position: absolute; top: 0; right: 0; width: 0; height: 0; border-style: solid; border-width: 0 56px 56px 0; border-color: transparent var(--pale-blue) transparent transparent; }

      /* Flagship (clickable, rich) */
      .flagship { padding: 1.6rem; }
      .flagship .label { font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--teal-blue); }
      .flagship h3 { font-size: 1.5rem; margin: 0.35rem 0 0.5rem; }
      .flagship .outcome { margin: 0 0 1rem; }
      .receipts { display: flex; flex-wrap: wrap; gap: 0.4rem 1.25rem; font-family: var(--font-mono); font-size: 0.72rem; color: var(--body); border-top: 1px dashed var(--line); padding-top: 0.9rem; margin-top: 0.5rem; }
      .receipts b { color: var(--ink); font-weight: 500; }
      .flagship .links { margin-top: 1rem; display: flex; gap: 1.1rem; font-weight: 600; font-size: 0.9rem; }

      /* Card tier (NOT clickable, compact) */
      .mini { padding: 1.25rem; }
      .mini h4 { font-size: 1.1rem; margin-bottom: 0.35rem; }
      .mini .outcome { font-size: 0.95rem; margin: 0 0 0.8rem; }
      .mini .foot { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; }
      .mini .stack { font-family: var(--font-mono); font-size: 0.7rem; color: var(--teal-blue); }

      footer { padding: 2.5rem 0 4rem; color: var(--body); font-size: 0.85rem; }
    </style>
  </head>
  <body>
    <div class="preview-note">
      <strong>Phase 1 - Visual System Preview (spec §3).</strong> Not indexed, not yet applied to
      any live page. Approve the direction and I will lift these tokens into global.css and roll it
      out page by page.
    </div>
    <div class="motif-bar"></div>

    <!-- HERO sample (shows the §4 landing feel) -->
    <header class="hero">
      <div class="wrap">
        <p class="eyebrow">KenAshe.ai</p>
        <h1>Building with AI in Public</h1>
        <p class="tagline">An operator's case for shipping with AI.</p>
        <p class="subhead">
          I'm Ken Ashe, an AI application builder documenting real systems across agents,
          automations, AI-assisted websites, and marketing workflows, including what shipped, what
          broke, and what others can learn.
        </p>
        <div class="btn-row">
          <a class="btn btn-primary" href="#">View Projects</a>
          <a class="btn btn-ghost" href="#">Visit the Newsroom</a>
        </div>
        <p class="trust">AI application builder · CPA · PMP · Building with AI in public</p>
      </div>
    </header>

    <!-- PALETTE -->
    <section>
      <div class="wrap">
        <p class="eyebrow">Palette</p>
        <h2>Bright AI lab, not dark portfolio</h2>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#011338"></div><div class="meta"><b>Deep navy</b>#011338 · headings</div></div>
          <div class="swatch"><div class="chip" style="background:#183473"></div><div class="meta"><b>Dark blue</b>#183473</div></div>
          <div class="swatch"><div class="chip" style="background:#2E74C9"></div><div class="meta"><b>Core blue</b>#2E74C9</div></div>
          <div class="swatch"><div class="chip" style="background:#5795F5"></div><div class="meta"><b>Bright blue</b>#5795F5</div></div>
          <div class="swatch"><div class="chip" style="background:#0871AC"></div><div class="meta"><b>Teal-blue</b>#0871AC</div></div>
          <div class="swatch"><div class="chip" style="background:#C7DAFB"></div><div class="meta"><b>Pale blue</b>#C7DAFB</div></div>
          <div class="swatch"><div class="chip" style="background:#F5F7FC;border-bottom:1px solid #dbe4f5"></div><div class="meta"><b>Ice background</b>#F5F7FC</div></div>
          <div class="swatch"><div class="chip" style="background:#FDFDFD;border-bottom:1px solid #dbe4f5"></div><div class="meta"><b>White</b>#FDFDFD</div></div>
          <div class="swatch"><div class="chip" style="background:linear-gradient(135deg,#0871AC,#2E74C9,#5795F5,#183473)"></div><div class="meta"><b>Accent gradient</b>matches the logo</div></div>
        </div>
      </div>
    </section>

    <!-- TYPE -->
    <section>
      <div class="wrap">
        <p class="eyebrow">Typography</p>
        <h2>Large, confident, navy headings; slate-blue body</h2>
        <div class="type-row"><span>Display / H1 · Plus Jakarta Sans 800</span><h1 style="font-size:3rem">Ship the work, show the receipts</h1></div>
        <div class="type-row"><span>H2 · 700</span><h2>Practical AI applications, documented in public</h2></div>
        <div class="type-row"><span>H3 · 700</span><h3 style="font-size:1.4rem">Six-agent email response team</h3></div>
        <div class="type-row"><span>Body · Inter 400/500</span><p style="margin:0;max-width:42rem">Credibility is conferred by receipts: a dense, navigable, honestly documented trail of real shipped systems. The site makes the learning legible as expertise.</p></div>
        <div class="type-row"><span>Mono / receipts · JetBrains Mono</span><p style="font-family:var(--font-mono);font-size:0.8rem;margin:0;color:var(--dark-blue)">shipped 2026-06-24 · runs/wk 140 · saves 45 min/day</p></div>
      </div>
    </section>

    <!-- BUTTONS + BADGES -->
    <section>
      <div class="wrap">
        <p class="eyebrow">Buttons &amp; status</p>
        <h2>Actions and lifecycle badges</h2>
        <div class="btn-row" style="margin-bottom:1.75rem">
          <a class="btn btn-primary" href="#">Primary action</a>
          <a class="btn btn-ghost" href="#">Secondary action</a>
        </div>
        <div class="badges">
          <span class="badge inprogress">In progress</span>
          <span class="badge live">LIVE</span>
          <span class="badge shipped">SHIPPED</span>
          <span class="badge archived">Archived</span>
        </div>
      </div>
    </section>

    <!-- CARDS -->
    <section>
      <div class="wrap">
        <p class="eyebrow">Projects components (§5)</p>
        <h2>Two tiers: clickable flagships, non-clickable cards</h2>

        <div class="cards" style="margin-bottom:1.5rem">
          <div class="card flagship">
            <span class="label">Case study</span>
            <div style="display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap">
              <h3>Autonomous blog publishing system</h3>
              <span class="badge live">LIVE</span>
            </div>
            <p class="outcome">A self-running content system that researches, drafts, QA-gates, and publishes on its own. (Sample data for layout.)</p>
            <div class="receipts">
              <span><b>Shipped</b> 2026-06-24</span>
              <span><b>Stack</b> GitHub Actions · n8n · Opus 4.8 · GPT-5.5 · Gemini 3.1 Pro · pgvector</span>
              <span><b>Status</b> fully autonomous</span>
            </div>
            <div class="links">
              <a href="#">Read case study →</a>
              <a href="#">View build log →</a>
            </div>
          </div>
        </div>

        <p class="eyebrow" style="margin-top:2rem">More builds (card tier - not clickable)</p>
        <div class="cards grid-2">
          <div class="card mini">
            <div style="display:flex;justify-content:space-between;align-items:start;gap:0.5rem">
              <h4>Six-agent email response team</h4>
              <span class="badge live">LIVE</span>
            </div>
            <p class="outcome">Drafts replies across a shared inbox before the first coffee. (Sample.)</p>
            <div class="foot"><span class="stack">Claude · n8n · Gmail API</span></div>
          </div>
          <div class="card mini">
            <div style="display:flex;justify-content:space-between;align-items:start;gap:0.5rem">
              <h4>Personal assistant chatbot</h4>
              <span class="badge shipped">SHIPPED</span>
            </div>
            <p class="outcome">Answers from a private knowledge base on demand. (Sample.)</p>
            <div class="foot"><span class="stack">Claude API · RAG</span></div>
          </div>
        </div>
        <p style="font-size:0.8rem;color:var(--body);margin-top:0.9rem">Card content above is placeholder for layout only; real cards use the receipts you provide (no fabrication).</p>
      </div>
    </section>

    <footer>
      <div class="wrap">
        KenAshe.ai visual-system preview · Phase 1 · spec v2.2 §3 · this route is a temporary
        reference and will be removed once the system is rolled into the live pages.
      </div>
    </footer>
  </body>
</html>
