---
// THROWAWAY theme preview (noindex). Self-contained: does NOT import global.css
// or BaseLayout, so it neither inherits nor affects the live site. Renders the
// real §4 homepage sections through ONE token contract; each palette just
// redefines the token VALUES on html[data-theme]. Whatever Ken picks, these
// exact values lift straight into global.css. Delete this route once chosen.
import { projects, type Project } from '../../data/builds';

const featTitles = [
  'Six-agent email response team',
  'Daily email to myself',
  'Sir Pitches-a-lot',
  'kenashe.ai',
];
const featured = featTitles
  .map((t) => projects.find((p) => p.title === t))
  .filter((p): p is Project => p !== undefined);

const pillars = [
  { name: 'Agents', body: 'Task-scoped agents that research, draft, qualify, and act on real tools and data.' },
  { name: 'Automations', body: 'Scheduled and event-driven pipelines that do real work without me starting them.' },
  { name: 'AI-assisted websites', body: 'Sites designed, built, and shipped with AI coding tools, live on real domains.' },
  { name: 'Workflow apps', body: 'Internal tools that turn a manual process into something repeatable and fast.' },
];

const topics = [
  'Building with AI in public',
  'Practical AI for operators',
  'AI agents and workflow automation',
  'AI-assisted website development',
];

const themes = [
  { key: 'warm-dark', name: 'Warm dark (refined)', sw: ['#16130E', '#FFB300', '#F3EEE3'] },
  { key: 'midnight', name: 'Midnight signal', sw: ['#0B1020', '#5C8BFF', '#22D3EE'] },
  { key: 'paper', name: 'Warm paper', sw: ['#FAF6EE', '#C2521A', '#1D1813'] },
  { key: 'studio', name: 'Studio (navy + gold)', sw: ['#F4F7F7', '#0C2340', '#E0A638'] },
];
---

<!doctype html>
<html lang="en" data-theme="warm-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Theme preview - KenAshe.ai</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* ---- Token contract (one set of names; each theme redefines values) ---- */
      html[data-theme='warm-dark'] {
        --bg: #16130e; --surface: #211b12; --border: #34291a; --fg: #f4efe4; --muted: #ac9f8b;
        --accent: #ffb300; --on-accent: #1a1206; --accent-2: #f2a93b; --eyebrow: #ffb300;
        --grad: linear-gradient(135deg, #ffb300, #e07b1a);
        --shadow: 0 12px 30px rgba(0,0,0,.5); --shadow-sm: 0 1px 2px rgba(0,0,0,.4); --radius: 9px;
        --band-bg: #0e0b06; --band-fg: #f4efe4; --band-sub: #c9bca6; --band-eyebrow: #ffb300;
      }
      html[data-theme='midnight'] {
        --bg: #0b1020; --surface: #131c30; --border: #243049; --fg: #eaf0fa; --muted: #8e9cb4;
        --accent: #5c8bff; --on-accent: #0a0f1e; --accent-2: #22d3ee; --eyebrow: #5c8bff;
        --grad: linear-gradient(135deg, #5c8bff, #22d3ee);
        --shadow: 0 14px 34px rgba(0,0,0,.55); --shadow-sm: 0 1px 2px rgba(0,0,0,.45); --radius: 13px;
        --band-bg: #060a14; --band-fg: #eaf0fa; --band-sub: #aab6cc; --band-eyebrow: #5c8bff;
      }
      html[data-theme='paper'] {
        --bg: #faf6ee; --surface: #ffffff; --border: #ece3d4; --fg: #1d1813; --muted: #6e6353;
        --accent: #c2521a; --on-accent: #ffffff; --accent-2: #e08a2b; --eyebrow: #c2521a;
        --grad: linear-gradient(135deg, #c2521a, #e08a2b);
        --shadow: 0 14px 34px -16px rgba(60,40,20,.28); --shadow-sm: 0 1px 2px rgba(60,40,20,.12); --radius: 11px;
        --band-bg: #1d1813; --band-fg: #faf6ee; --band-sub: #cbbba6; --band-eyebrow: #e08a2b;
      }
      html[data-theme='studio'] {
        --bg: #f4f7f7; --surface: #ffffff; --border: #e4eaea; --fg: #0c2340; --muted: #586a7c;
        --accent: #0c2340; --on-accent: #ffffff; --accent-2: #e0a638; --eyebrow: #b5800e;
        --grad: linear-gradient(135deg, #16406f, #0c2340);
        --shadow: 0 16px 40px -18px rgba(12,35,64,.24); --shadow-sm: 0 4px 14px -8px rgba(12,35,64,.18); --radius: 16px;
        --band-bg: #0c2340; --band-fg: #ffffff; --band-sub: #bcd0e6; --band-eyebrow: #e0a638;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Inter', system-ui, sans-serif;
        line-height: 1.6;
        transition: background-color 200ms ease, color 200ms ease;
      }

      /* ---- Switcher chrome (theme-independent tooling) ---- */
      .switcher {
        position: sticky; top: 0; z-index: 50;
        display: flex; flex-wrap: wrap; align-items: center; gap: .5rem .9rem;
        background: #14161b; color: #e7e9ee;
        padding: .7rem 1.1rem; border-bottom: 1px solid #2a2e38;
        font-family: 'JetBrains Mono', monospace;
      }
      .switcher-label { font-size: .72rem; letter-spacing: .12em; text-transform: uppercase; color: #9aa1b1; margin-right: .25rem; }
      .switcher-btn {
        display: inline-flex; align-items: center; gap: .5rem;
        background: #20242e; color: #cfd4df; border: 1px solid #2f3543;
        padding: .4rem .7rem; border-radius: 999px; cursor: pointer;
        font-family: inherit; font-size: .8rem;
      }
      .switcher-btn[aria-pressed='true'] { background: #fff; color: #14161b; border-color: #fff; }
      .sw-dots { display: inline-flex; gap: 3px; }
      .sw-dot { width: 10px; height: 10px; border-radius: 999px; border: 1px solid rgba(255,255,255,.25); }
      .switcher-note { flex-basis: 100%; font-size: .72rem; color: #828a9b; }

      /* ---- Shared layout ---- */
      .motif-bar { height: 5px; background: var(--grad); }
      .wrap { max-width: 64rem; margin: 0 auto; padding: 0 1.5rem; }
      .eyebrow {
        font-family: 'JetBrains Mono', monospace; font-size: .7rem; letter-spacing: .16em;
        text-transform: uppercase; color: var(--eyebrow); margin: 0 0 .85rem;
      }
      .section { padding: 4rem 0; }
      .section-title {
        font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700;
        font-size: clamp(1.5rem, 3vw, 2.2rem); letter-spacing: -.025em; line-height: 1.1;
        color: var(--fg); margin: 0 0 2rem; max-width: 24ch;
      }

      /* ---- Buttons ---- */
      .ctas { display: flex; flex-wrap: wrap; gap: .75rem; }
      .btn {
        display: inline-flex; align-items: center; gap: .45rem; text-decoration: none;
        font-family: 'Inter', sans-serif; font-weight: 600; font-size: .95rem;
        padding: .72rem 1.3rem; border-radius: calc(var(--radius) - 4px); border: 1px solid transparent;
        transition: transform 150ms ease, box-shadow 150ms ease;
      }
      .btn-primary { background: var(--grad); color: var(--on-accent); box-shadow: var(--shadow-sm); }
      .btn-primary:hover { transform: translateY(-1px); box-shadow: var(--shadow); }
      .btn-ghost { background: var(--surface); color: var(--fg); border-color: var(--border); }

      /* ---- Hero ---- */
      .hero { position: relative; overflow: hidden; background: var(--surface); padding: 5rem 0 4rem; }
      .hero::after {
        content: ''; position: absolute; right: -130px; bottom: -150px; width: 360px; height: 360px;
        background: var(--grad); opacity: .12; transform: rotate(18deg); border-radius: 56px; pointer-events: none;
      }
      .hero-inner { position: relative; z-index: 1; }
      .h1 {
        font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800;
        font-size: clamp(2.6rem, 6.5vw, 4.75rem); letter-spacing: -.03em; line-height: 1.02;
        color: var(--fg); margin: 0 0 1.25rem; max-width: 18ch;
      }
      .sub { font-size: clamp(1.0625rem, 1.7vw, 1.3rem); line-height: 1.5; color: var(--muted); margin: 0 0 1.9rem; max-width: 40rem; }
      .trust { font-family: 'JetBrains Mono', monospace; font-size: .8rem; color: var(--accent-2); letter-spacing: .02em; margin: 1.75rem 0 0; }

      /* ---- Cards (shared) ---- */
      .card {
        position: relative; background: var(--surface); border: 1px solid var(--border);
        border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden;
      }
      .card::before {
        content: ''; position: absolute; top: 0; right: 0; width: 0; height: 0; border-style: solid;
        border-width: 0 44px 44px 0;
        border-color: transparent color-mix(in oklab, var(--accent-2) 22%, var(--surface)) transparent transparent;
      }
      .grid { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
      .pillar { padding: 1.5rem 1.4rem; }
      .pillar h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--fg); margin: 0 0 .55rem; }
      .pillar p { font-size: .95rem; line-height: 1.55; color: var(--muted); margin: 0; }

      .featured-grid { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); }
      .proj { padding: 1.5rem 1.5rem 1.35rem; }
      .proj-head { display: flex; align-items: baseline; justify-content: space-between; gap: .85rem; margin-bottom: .6rem; }
      .proj-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.2rem; font-weight: 700; color: var(--fg); margin: 0; }
      .proj-dek { font-size: .95rem; line-height: 1.55; color: var(--muted); margin: 0 0 1.1rem; }
      .status {
        flex-shrink: 0; font-family: 'JetBrains Mono', monospace; font-size: .62rem; font-weight: 500;
        letter-spacing: .08em; text-transform: uppercase; padding: .28rem .55rem; border-radius: 999px;
        border: 1px solid var(--border); color: var(--muted); background: var(--bg);
      }
      .stack { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: .4rem; }
      .stack li {
        font-family: 'JetBrains Mono', monospace; font-size: .72rem; color: var(--muted);
        background: var(--bg); border: 1px solid var(--border); border-radius: 5px; padding: .24rem .5rem;
      }

      /* ---- Media band (per-theme dark feature band) ---- */
      .band { position: relative; overflow: hidden; background: var(--band-bg); padding: 4rem 0; }
      .band .eyebrow { color: var(--band-eyebrow); }
      .band-title { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: clamp(1.6rem, 3.2vw, 2.3rem); letter-spacing: -.025em; line-height: 1.14; color: var(--band-fg); margin: 0 0 1.5rem; max-width: 26ch; }
      .chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: .6rem; }
      .chips li { font-size: .9rem; color: var(--band-sub); background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.16); border-radius: 999px; padding: .45rem .9rem; }

      /* ---- Final CTA ---- */
      .final { background: color-mix(in oklab, var(--accent-2) 8%, var(--bg)); border-top: 1px solid var(--border); }
      .final-inner { text-align: center; max-width: 44rem; margin: 0 auto; padding: 4.5rem 1.5rem; }
      .final h2 { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.7rem, 3.6vw, 2.5rem); letter-spacing: -.03em; line-height: 1.08; color: var(--fg); margin: 0 0 1rem; }
      .final p { font-size: 1.0625rem; color: var(--muted); margin: 0 auto 1.9rem; max-width: 34rem; }
      .final .ctas { justify-content: center; }
    </style>
  </head>

  <body>
    <!-- SWITCHER (tooling chrome, not part of the design) -->
    <div class="switcher">
      <span class="switcher-label">Palette</span>
      {
        themes.map((t, i) => (
          <button
            class="switcher-btn"
            data-theme-key={t.key}
            data-theme-name={t.name}
            aria-pressed={i === 0 ? 'true' : 'false'}
          >
            <span class="sw-dots">
              {t.sw.map((c) => (
                <span class="sw-dot" style={`background:${c}`} />
              ))}
            </span>
            {t.name}
          </button>
        ))
      }
      <span class="switcher-note">
        Same layout and content - only the color palette changes. Currently viewing:
        <strong id="theme-name">Warm dark (refined)</strong>.
      </span>
    </div>

    <div class="motif-bar"></div>

    <!-- HERO -->
    <header class="hero">
      <div class="wrap hero-inner">
        <p class="eyebrow">KenAshe.ai</p>
        <h1 class="h1">Building with AI in Public</h1>
        <p class="sub">
          I'm Ken Ashe, an AI application builder documenting real systems across agents,
          automations, AI-assisted websites, and marketing workflows, including what shipped, what
          broke, and what others can learn.
        </p>
        <div class="ctas">
          <a class="btn btn-primary" href="#">View Projects <span aria-hidden="true">→</span></a>
          <a class="btn btn-ghost" href="#">Visit the Newsroom</a>
        </div>
        <p class="trust">AI application builder · CPA · PMP · Building with AI in public</p>
      </div>
    </header>

    <!-- MEDIA BAND -->
    <section class="band">
      <div class="wrap">
        <p class="eyebrow">For media</p>
        <h2 class="band-title">Available for interviews, podcasts, speaking, and AI commentary.</h2>
        <ul class="chips">
          {topics.map((t) => <li>{t}</li>)}
        </ul>
      </div>
    </section>

    <!-- WHAT I BUILD -->
    <section class="section">
      <div class="wrap">
        <p class="eyebrow">What I build</p>
        <h2 class="section-title">Practical AI applications, four ways.</h2>
        <ul class="grid">
          {
            pillars.map((p) => (
              <li class="card pillar">
                <h3>{p.name}</h3>
                <p>{p.body}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- FEATURED PROJECTS -->
    <section class="section" style="padding-top:0">
      <div class="wrap">
        <p class="eyebrow">Featured projects</p>
        <h2 class="section-title">Shipped, running, and documented.</h2>
        <ul class="featured-grid">
          {
            featured.map((p) => (
              <li class="card proj">
                <div class="proj-head">
                  <h3 class="proj-title">{p.title}</h3>
                  <span class="status">{p.status}</span>
                </div>
                <p class="proj-dek">{p.dek}</p>
                <ul class="stack">
                  {p.stack.map((s) => (
                    <li>{s}</li>
                  ))}
                </ul>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final">
      <div class="final-inner">
        <h2>Building something with AI, or writing about someone who is?</h2>
        <p>Reach out for interviews, speaking, partnerships, or to compare notes on building with AI.</p>
        <div class="ctas">
          <a class="btn btn-primary" href="#">Get in touch <span aria-hidden="true">→</span></a>
          <a class="btn btn-ghost" href="#">Press &amp; media kit</a>
        </div>
      </div>
    </section>

    <script is:inline>
      (function () {
        const root = document.documentElement;
        const btns = Array.from(document.querySelectorAll('[data-theme-key]'));
        const nameEl = document.getElementById('theme-name');
        btns.forEach((btn) => {
          btn.addEventListener('click', () => {
            root.setAttribute('data-theme', btn.getAttribute('data-theme-key'));
            btns.forEach((b) => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
            if (nameEl) nameEl.textContent = btn.getAttribute('data-theme-name');
          });
        });
      })();
    </script>
  </body>
</html>
