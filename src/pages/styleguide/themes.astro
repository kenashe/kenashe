---
// THROWAWAY theme preview (noindex). Self-contained: does NOT import global.css
// or BaseLayout, so it neither inherits nor affects the live site.
//
// v2 - CLEAN treatment. The §3 ornaments (diagonal gradient slab, card corner
// triangles, gradient bars, dark gradient band) are removed. This is the
// restrained, typographic language of the ORIGINAL site: flat sections,
// hairline rules, plain bordered cards, solid accent, big confident type.
// One token contract; each palette just redefines the values, so whatever Ken
// picks lifts straight into global.css. Delete this route once chosen.
import { projects, type Project } from '../../data/builds';

const featTitles = [
  'Six-agent email response team',
  'Daily email to myself',
  'Sir Pitches-a-lot',
  'kenashe.ai',
];
const featured = featTitles
  .map((t) => projects.find((p) => p.title === t))
  .filter((p): p is Project => p !== undefined);

const pillars = [
  { name: 'Agents', body: 'Task-scoped agents that research, draft, qualify, and act on real tools and data.' },
  { name: 'Automations', body: 'Scheduled and event-driven pipelines that do real work without me starting them.' },
  { name: 'AI-assisted websites', body: 'Sites designed, built, and shipped with AI coding tools, live on real domains.' },
  { name: 'Workflow apps', body: 'Internal tools that turn a manual process into something repeatable and fast.' },
];

const topics = [
  'Building with AI in public',
  'Practical AI for operators',
  'AI agents and workflow automation',
  'AI-assisted website development',
];

const themes = [
  { key: 'warm-dark', name: 'Warm dark (refined)', sw: ['#16130E', '#FFB300', '#F3EEE3'] },
  { key: 'midnight', name: 'Midnight signal', sw: ['#0B1020', '#5C8BFF', '#EAF0FA'] },
  { key: 'paper', name: 'Warm paper', sw: ['#FAF6EE', '#C2521A', '#1D1813'] },
  { key: 'studio', name: 'Studio (navy + white)', sw: ['#FFFFFF', '#0C2340', '#586A7C'] },
];
---

<!doctype html>
<html lang="en" data-theme="warm-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Theme preview (clean) - KenAshe.ai</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* ---- Token contract (one set of names; each theme redefines values) ---- */
      html[data-theme='warm-dark'] {
        --bg: #16130e; --surface: #1e1a12; --border: #34291a; --rule: #2a2218;
        --fg: #f4efe4; --muted: #a89f8c; --accent: #ffb300; --on-accent: #16130e;
      }
      html[data-theme='midnight'] {
        --bg: #0b1020; --surface: #131c30; --border: #243049; --rule: #1b2438;
        --fg: #eaf0fa; --muted: #8e9cb4; --accent: #5c8bff; --on-accent: #0a0f1e;
      }
      html[data-theme='paper'] {
        --bg: #faf6ee; --surface: #ffffff; --border: #e7decd; --rule: #ece3d4;
        --fg: #1d1813; --muted: #6e6353; --accent: #c2521a; --on-accent: #ffffff;
      }
      html[data-theme='studio'] {
        --bg: #ffffff; --surface: #ffffff; --border: #e4eaea; --rule: #eaeeee;
        --fg: #0c2340; --muted: #586a7c; --accent: #0c2340; --on-accent: #ffffff;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg); color: var(--fg);
        font-family: 'Inter', system-ui, sans-serif; line-height: 1.65;
        transition: background-color 200ms ease, color 200ms ease;
      }

      /* ---- Switcher chrome (theme-independent tooling) ---- */
      .switcher {
        position: sticky; top: 0; z-index: 50; display: flex; flex-wrap: wrap;
        align-items: center; gap: .5rem .9rem; background: #14161b; color: #e7e9ee;
        padding: .7rem 1.1rem; border-bottom: 1px solid #2a2e38; font-family: 'JetBrains Mono', monospace;
      }
      .switcher-label { font-size: .72rem; letter-spacing: .12em; text-transform: uppercase; color: #9aa1b1; }
      .switcher-btn {
        display: inline-flex; align-items: center; gap: .5rem; background: #20242e; color: #cfd4df;
        border: 1px solid #2f3543; padding: .4rem .7rem; border-radius: 999px; cursor: pointer;
        font-family: inherit; font-size: .8rem;
      }
      .switcher-btn[aria-pressed='true'] { background: #fff; color: #14161b; border-color: #fff; }
      .sw-dots { display: inline-flex; gap: 3px; }
      .sw-dot { width: 10px; height: 10px; border-radius: 999px; border: 1px solid rgba(255,255,255,.25); }
      .switcher-note { flex-basis: 100%; font-size: .72rem; color: #828a9b; }

      /* ---- Layout: narrow editorial column ---- */
      .wrap { max-width: 50rem; margin: 0 auto; padding: 0 1.5rem; }
      .mark { font-family: 'JetBrains Mono', monospace; color: var(--accent); }

      /* ---- Hero (flat, big type) ---- */
      .hero { padding: 5rem 0 1rem; }
      .eyebrow { font-family: 'JetBrains Mono', monospace; font-size: .8rem; color: var(--muted); letter-spacing: .02em; margin: 0 0 1.5rem; }
      .h1 {
        font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800;
        font-size: clamp(2.7rem, 7vw, 5rem); letter-spacing: -.035em; line-height: 1; color: var(--fg);
        margin: 0 0 1.4rem; max-width: 16ch;
      }
      .sub { font-size: clamp(1.0625rem, 1.7vw, 1.3rem); line-height: 1.5; color: var(--muted); margin: 0 0 2rem; max-width: 38rem; }
      .ctas { display: flex; flex-wrap: wrap; gap: .75rem; }
      .btn {
        display: inline-flex; align-items: center; gap: .4rem; text-decoration: none;
        font-family: 'Inter', sans-serif; font-weight: 500; font-size: .95rem;
        padding: .7rem 1.15rem; border-radius: 5px; border: 1px solid transparent;
        transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;
      }
      .btn-primary { background: var(--accent); color: var(--on-accent); border-color: var(--accent); }
      .btn-primary:hover { background: var(--fg); border-color: var(--fg); color: var(--bg); }
      .btn-ghost { background: transparent; color: var(--fg); border-color: var(--border); }
      .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
      .trust { font-family: 'JetBrains Mono', monospace; font-size: .8rem; color: var(--muted); letter-spacing: .02em; margin: 1.75rem 0 0; }

      /* ---- Principles: big-type moment between hairline rules ---- */
      .principles { margin: 4.5rem 0; padding: 3.5rem 0; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
      .principles .mark { font-size: .8rem; letter-spacing: .12em; display: block; margin-bottom: 1.4rem; }
      .principle { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(2rem, 6vw, 3.6rem); letter-spacing: -.035em; line-height: 1.05; color: var(--fg); margin: 0; }
      .principle + .principle { margin-top: .25rem; }

      /* ---- Blocks: tiny uppercase label + hairline rule ---- */
      .block { margin: 3.5rem 0; }
      .block-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; border-bottom: 1px solid var(--rule); padding-bottom: .55rem; margin-bottom: 1.4rem; }
      .block-head h2 { font-family: 'Inter', sans-serif; font-size: .8rem; font-weight: 600; letter-spacing: .09em; text-transform: uppercase; color: var(--muted); margin: 0; }
      .block-link { font-family: 'Inter', sans-serif; font-size: .82rem; color: var(--muted); text-decoration: none; }
      .block-link:hover { color: var(--accent); }

      /* ---- Plain bordered cards (no shadow, no corner motif) ---- */
      .card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 1.4rem 1.4rem 1.25rem; transition: border-color 180ms ease, transform 180ms ease; }
      .card:hover { border-color: var(--accent); transform: translateY(-2px); }

      .pillars { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); }
      .pillar h3 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.15rem; font-weight: 700; color: var(--fg); margin: 0 0 .5rem; }
      .pillar p { font-size: .94rem; line-height: 1.55; color: var(--muted); margin: 0; }

      .receipts { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem; }
      .proj-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: .6rem; }
      .proj-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.2rem, 2.2vw, 1.5rem); font-weight: 700; letter-spacing: -.02em; color: var(--fg); margin: 0; }
      .proj-dek { font-size: 1rem; line-height: 1.55; color: var(--fg); margin: 0 0 1.1rem; max-width: 44rem; }
      .status { flex-shrink: 0; display: inline-flex; align-items: center; gap: .45em; font-family: 'JetBrains Mono', monospace; font-size: .68rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); border: 1px solid var(--border); border-radius: 999px; padding: .3rem .55rem; }
      .status .dot { width: .4rem; height: .4rem; border-radius: 999px; background: currentColor; }
      .status-live { color: var(--accent); border-color: color-mix(in oklab, var(--accent) 40%, var(--border)); }
      .stack { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: .4rem; }
      .stack li { font-family: 'JetBrains Mono', monospace; font-size: .72rem; color: var(--muted); background: var(--bg); border: 1px solid var(--border); border-radius: 4px; padding: .24rem .5rem; }

      /* ---- Available-for: plain rows, no band ---- */
      .avail-row { display: flex; flex-wrap: wrap; gap: .5rem 1.5rem; font-size: 1.0625rem; color: var(--fg); margin: 0 0 1.25rem; }
      .topics { list-style: none; margin: 0; padding: 0; display: grid; gap: .35rem; }
      .topics li { font-size: 1rem; color: var(--muted); padding-left: 1.1rem; position: relative; }
      .topics li::before { content: '/'; position: absolute; left: 0; color: var(--accent); font-family: 'JetBrains Mono', monospace; }

      /* ---- Final CTA (flat block) ---- */
      .final { margin: 4.5rem 0 5rem; padding-top: 3rem; border-top: 1px solid var(--rule); }
      .final h2 { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: clamp(1.7rem, 4vw, 2.6rem); letter-spacing: -.03em; line-height: 1.08; color: var(--fg); margin: 0 0 1rem; max-width: 20ch; }
      .final p { font-size: 1.0625rem; color: var(--muted); margin: 0 0 1.6rem; max-width: 34rem; }
    </style>
  </head>

  <body>
    <div class="switcher">
      <span class="switcher-label">Palette</span>
      {
        themes.map((t, i) => (
          <button class="switcher-btn" data-theme-key={t.key} data-theme-name={t.name} aria-pressed={i === 0 ? 'true' : 'false'}>
            <span class="sw-dots">
              {t.sw.map((c) => (
                <span class="sw-dot" style={`background:${c}`} />
              ))}
            </span>
            {t.name}
          </button>
        ))
      }
      <span class="switcher-note">
        Clean treatment - ornaments removed (no gradient slabs, no corner triangles). Viewing:
        <strong id="theme-name">Warm dark (refined)</strong>.
      </span>
    </div>

    <main class="wrap">
      <!-- HERO -->
      <header class="hero">
        <p class="eyebrow"><span class="mark">//</span> KenAshe.ai</p>
        <h1 class="h1">Building with AI in Public</h1>
        <p class="sub">
          I'm Ken Ashe, an AI application builder documenting real systems across agents,
          automations, AI-assisted websites, and marketing workflows, including what shipped, what
          broke, and what others can learn.
        </p>
        <div class="ctas">
          <a class="btn btn-primary" href="#">View Projects <span aria-hidden="true">→</span></a>
          <a class="btn btn-ghost" href="#">Visit the Newsroom</a>
        </div>
        <p class="trust"><span class="mark">//</span> AI application builder · CPA · PMP · Building with AI in public</p>
      </header>

      <!-- PRINCIPLES (big-type moment) -->
      <section class="principles">
        <span class="mark">// principles</span>
        <p class="principle">No hype.</p>
        <p class="principle">No doom.</p>
        <p class="principle">Receipts only.</p>
      </section>

      <!-- WHAT I BUILD -->
      <section class="block">
        <div class="block-head"><h2>What I build</h2></div>
        <ul class="pillars">
          {
            pillars.map((p) => (
              <li class="card">
                <h3>{p.name}</h3>
                <p>{p.body}</p>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- FEATURED PROJECTS -->
      <section class="block">
        <div class="block-head"><h2>Featured projects</h2><a class="block-link" href="#">All projects →</a></div>
        <ul class="receipts">
          {
            featured.map((p) => (
              <li class="card">
                <div class="proj-head">
                  <h3 class="proj-title">{p.title}</h3>
                  <span class={`status status-${p.status.toLowerCase()}`}>
                    <span class="dot" aria-hidden="true" />
                    {p.status}
                  </span>
                </div>
                <p class="proj-dek">{p.dek}</p>
                <ul class="stack">
                  {p.stack.map((s) => (
                    <li>{s}</li>
                  ))}
                </ul>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- AVAILABLE FOR (media) -->
      <section class="block">
        <div class="block-head"><h2>Available for</h2></div>
        <p class="avail-row"><span>Media interviews</span><span>Podcast appearances</span><span>Speaking</span><span>AI commentary</span></p>
        <ul class="topics">
          {topics.map((t) => <li>{t}</li>)}
        </ul>
      </section>

      <!-- FINAL CTA -->
      <section class="final">
        <h2>Building something with AI, or writing about someone who is?</h2>
        <p>Reach out for interviews, speaking, partnerships, or to compare notes on building with AI.</p>
        <div class="ctas">
          <a class="btn btn-primary" href="#">Get in touch <span aria-hidden="true">→</span></a>
          <a class="btn btn-ghost" href="#">Press &amp; media kit</a>
        </div>
      </section>
    </main>

    <script is:inline>
      (function () {
        const root = document.documentElement;
        const btns = Array.from(document.querySelectorAll('[data-theme-key]'));
        const nameEl = document.getElementById('theme-name');
        btns.forEach((btn) => {
          btn.addEventListener('click', () => {
            root.setAttribute('data-theme', btn.getAttribute('data-theme-key'));
            btns.forEach((b) => b.setAttribute('aria-pressed', b === btn ? 'true' : 'false'));
            if (nameEl) nameEl.textContent = btn.getAttribute('data-theme-name');
          });
        });
      })();
    </script>
  </body>
</html>
