---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Phase 0 - Newsroom + orphan fix (spec v2.2 §13/§18).
// Built on the EXISTING stack and visual conventions; the §3 bright-AI-lab
// visual system is Phase 1 and intentionally NOT applied here.
// Existing JSON-LD/entity work is untouched. This index links TO the existing
// release pages (it does not move, copy, or re-host them).

const description =
  'Newsroom for Ken Ashe: press releases, media kit, fast facts, and press contact for media covering practical AI application building.';

// Press releases live at their existing canonical URLs. We link to them here;
// we do not duplicate or rewrite them. Headlines/deks are the actual live text.
const releases = [
  {
    date: 'June 24, 2026',
    title:
      'KenAshe.ai Launches as a Public Build Log for Practical AI Projects and Website Development',
    href: '/news/site-launch/',
    external: false,
    summary:
      'Personal site from AI operator Ken Ashe documents AI builds, website development, automation experiments, and the process of building with AI in public',
  },
  {
    date: 'June 24, 2026',
    title:
      'Lucky Domains Launches Redesigned Website for Premium Domain Acquisition and SEO',
    href: 'https://luckydomains.io/news/website-relaunch.html',
    external: true,
    summary:
      'LuckyDomains.io positions the company as a focused partner for businesses that need a better domain name and durable search visibility',
  },
];

const sections = [
  { id: 'latest-news', label: 'Latest News' },
  { id: 'press-releases', label: 'Press Releases' },
  { id: 'media-kit', label: 'Media Kit' },
  { id: 'available-for-comment', label: 'Available for Comment' },
  { id: 'fast-facts', label: 'Fast Facts' },
  { id: 'press-contact', label: 'Press Contact' },
];

// Quote bank - verbatim from the live KenAshe.ai launch release (receipts only).
const quotes = [
  "AI is moving too quickly for theory alone. The point of this site is to show the work: what I'm building, what shipped, what broke, and what other operators can learn from it.",
  "The opportunity isn't talking about AI. It's learning to use it to build useful things. KenAshe.ai is where I'm documenting that process in public.",
];

const speakingTopics = [
  'Building with AI in public',
  'Practical AI for operators and non-engineers',
  'AI agents and workflow automation',
  'AI-assisted website development',
  'AI coding tools in real projects',
  'Marketing operations automation',
  'AI automation case studies',
];
---

<BaseLayout title="Newsroom" description={description}>
  <div class="page newsroom">
    <header class="page-header">
      <p class="page-mark" aria-hidden="true">// newsroom</p>
      <h1>Newsroom</h1>
      <p class="tagline">
        Press releases, media kit, and fast facts for journalists, podcasters, and editors
        covering Ken Ashe and KenAshe.ai. For interviews or comment, see
        <a href="#press-contact">Press Contact</a>.
      </p>
      <nav class="jump" aria-label="Newsroom sections">
        {sections.map((s) => <a href={`#${s.id}`}>{s.label}</a>)}
      </nav>
    </header>

    <!-- LATEST NEWS -->
    <section class="block" id="latest-news" aria-labelledby="latest-news-h">
      <h2 id="latest-news-h">Latest News</h2>
      <article class="lead-item">
        <p class="meta">June 24, 2026 · Announcement</p>
        <h3>
          <a href="/news/site-launch/"
            >KenAshe.ai Launches as a Public Build Log for Practical AI Projects and Website
            Development</a
          >
        </h3>
        <p class="summary">{releases[0].summary}.</p>
        <p class="more"><a href="/news/site-launch/">Read the full release →</a></p>
      </article>
    </section>

    <!-- PRESS RELEASES -->
    <section class="block" id="press-releases" aria-labelledby="press-releases-h">
      <h2 id="press-releases-h">Press Releases</h2>
      <ul class="release-list">
        {
          releases.map((r) => (
            <li class="release">
              <p class="meta">{r.date}</p>
              <h3>
                {r.external ? (
                  <a href={r.href} target="_blank" rel="noopener">
                    {r.title}
                  </a>
                ) : (
                  <a href={r.href}>{r.title}</a>
                )}
              </h3>
              <p class="summary">{r.summary}.</p>
              <p class="more">
                {r.external ? (
                  <a href={r.href} target="_blank" rel="noopener">
                    Read on LuckyDomains.io ↗
                  </a>
                ) : (
                  <a href={r.href}>Read the full release →</a>
                )}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- MEDIA KIT -->
    <section class="block" id="media-kit" aria-labelledby="media-kit-h">
      <h2 id="media-kit-h">Media Kit</h2>
      <p class="note">
        Preferred title: <strong>AI application builder</strong>. Trust line: <code
          >AI application builder · CPA · PMP · Building with AI in public</code
        >.
      </p>

      <h3 class="mk-sub">Bios</h3>
      <p class="bio-label">Short (≈50 words)</p>
      <p class="bio">
        Ken Ashe is an AI application builder who ships agents, automations, and AI-assisted
        websites, then documents the receipts in public at KenAshe.ai. A CPA and PMP, he builds
        practical AI systems and writes up what shipped, what broke, and what other builders can
        learn.
      </p>
      <p class="bio-label">Medium (≈150 words)</p>
      <p class="bio">
        Ken Ashe is an AI application builder documenting real systems in public at KenAshe.ai,
        spanning AI agents, automations, AI-assisted websites, and marketing workflows. He works at
        the application layer, turning existing models, APIs, coding tools, and automation platforms
        into useful systems, and publishes the receipts: what shipped, what broke, and what others
        can learn. A CPA and PMP with a background in digital marketing and project management, Ken
        pairs operator discipline with hands-on building rather than commentary. He is also the
        founder of Lucky Domains, a domain acquisition, brokerage, and SEO company. Based in New
        Jersey, he builds with AI in public under his own name and treats the work itself, a
        navigable trail of real shipped systems, as the credential. KenAshe.ai is the canonical home
        for that record.
      </p>
      <p class="bio-label">Long (≈300 words)</p>
      <p class="bio">
        Ken Ashe is an AI application builder who designs, ships, and documents practical AI systems
        in public at KenAshe.ai. His work spans four areas: AI agents, automations, AI-assisted
        websites, and workflow applications. The throughline is the application layer, taking
        existing models, APIs, coding tools, and automation platforms and turning them into systems
        that do real work, rather than training models or building infrastructure from scratch.
      </p>
      <p class="bio">
        He documents that work as receipts: a dense, honestly-kept trail of what he built, why,
        what broke, how he fixed it, and what other builders can reuse. That includes an autonomous
        content system he built and operates, the systems behind his own site, and tools he runs
        day to day. The bet is that the work, shown in detail, is more credible than authority
        claims, so the site leans on evidence over rhetoric.
      </p>
      <p class="bio">
        Ken is a CPA and PMP whose background also includes digital marketing and project
        management, a combination he uses to bring evidence, controls, and delivery discipline to AI
        builds. He is the founder of Lucky Domains, a domain acquisition, brokerage, and SEO
        company. Tool-agnostic by design, he works across whichever models and platforms fit the
        job. Based in New Jersey, he builds with AI in public under his own name. For media, he is
        available for interviews, podcast appearances, speaking, and AI commentary on practical AI
        application building.
      </p>

      <h3 class="mk-sub">Brand boilerplate</h3>
      <p class="bio">
        KenAshe.ai is the public build log of Ken Ashe, an AI application builder documenting real
        systems across agents, automations, AI-assisted websites, and marketing workflows,
        including what shipped, what broke, and what others can learn. Ken is a CPA and PMP, brings
        a digital marketing and project-management background, and is the founder of Lucky Domains,
        a domain acquisition, brokerage, and SEO company.
      </p>

      <h3 class="mk-sub">Assets</h3>
      <div class="assets">
        <figure class="asset">
          <img src="/images/ken-ashe.jpeg" alt="Headshot of Ken Ashe" width="320" height="320" />
          <figcaption>
            Headshot
            <a href="/images/ken-ashe.jpeg" download>Download JPEG</a>
          </figcaption>
        </figure>

        <figure class="asset">
          <img src="/og-default.png" alt="KenAshe.ai card image" width="320" height="168" />
          <figcaption>
            KenAshe.ai card image
            <a href="/og-default.png" download>Download PNG</a>
            <span class="flag">Flag: using the existing default social card (og-default.png). Confirm if a dedicated brand card is intended.</span>
          </figcaption>
        </figure>

        <figure class="asset asset-missing">
          <div class="placeholder-box" role="img" aria-label="KenAshe.ai logo placeholder">
            KA logo
          </div>
          <figcaption>
            <span class="flag">PLACEHOLDER: no KenAshe.ai logo asset exists in the repo (the site uses a text wordmark). Add the logo to /public and replace this before the wire.</span>
          </figcaption>
        </figure>
      </div>

      <h3 class="mk-sub">Quote bank</h3>
      <ul class="quotes">
        {quotes.map((q) => <li><blockquote>"{q}"</blockquote><cite>Ken Ashe</cite></li>)}
      </ul>

      <h3 class="mk-sub">Speaking topics</h3>
      <ul class="topics">
        {speakingTopics.map((t) => <li>{t}</li>)}
      </ul>

      <h3 class="mk-sub">Contact &amp; social</h3>
      <ul class="links">
        <li>Email: <a href="mailto:hello@kenashe.ai">hello@kenashe.ai</a></li>
        <li><a href="https://www.linkedin.com/in/kenashe/" target="_blank" rel="me noopener">LinkedIn</a></li>
        <li><a href="https://x.com/kenashe" target="_blank" rel="me noopener">X</a></li>
        <li><a href="https://github.com/kenashe" target="_blank" rel="me noopener">GitHub</a></li>
      </ul>
    </section>

    <!-- AVAILABLE FOR COMMENT -->
    <section class="block" id="available-for-comment" aria-labelledby="afc-h">
      <h2 id="afc-h">Available for Comment</h2>
      <p class="lead-line">
        Available for media interviews, podcast appearances, speaking, and AI commentary.
      </p>
      <ul class="topics">
        {speakingTopics.map((t) => <li>{t}</li>)}
      </ul>
      <p class="more"><a href="#press-contact">How to reach out →</a></p>
    </section>

    <!-- FAST FACTS -->
    <section class="block" id="fast-facts" aria-labelledby="ff-h">
      <h2 id="ff-h">Fast Facts</h2>
      <dl class="facts">
        <dt>Name</dt><dd>Ken Ashe</dd>
        <dt>Site</dt><dd><a href="/">kenashe.ai</a></dd>
        <dt>Location</dt><dd>New Jersey, USA</dd>
        <dt>Role</dt><dd>AI application builder</dd>
        <dt>Background</dt><dd>CPA, PMP, digital marketer, AI builder</dd>
        <dt>Focus</dt><dd>Agents, automations, AI-assisted websites, workflow systems</dd>
      </dl>
    </section>

    <!-- PRESS CONTACT -->
    <section class="block" id="press-contact" aria-labelledby="pc-h">
      <h2 id="pc-h">Press Contact</h2>
      <p class="lead-line">
        Media inquiries, interview requests, and comment: <a href="mailto:hello@kenashe.ai"
          >hello@kenashe.ai</a
        >.
      </p>
      <p class="note">
        Flag: a dedicated media contact form (general · media · speaking) is planned for the
        Phase 1 Contact page; until then, email is the press contact.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .page-header {
    margin-bottom: 3rem;
  }
  .page-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0 0 1rem;
    color: var(--fg);
  }
  .tagline {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 1.75rem;
    max-width: 38rem;
  }
  .tagline a { color: var(--fg); }
  .jump {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-top: 1rem;
    border-top: 1px solid var(--rule, var(--border));
  }
  .jump a { color: var(--muted); text-decoration: none; }
  .jump a:hover { color: var(--accent); }

  .block {
    margin: 3.25rem 0;
    padding-top: 2rem;
    border-top: 1px solid var(--rule, var(--border));
  }
  .block > h2 {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1.5rem;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.5rem;
  }
  h3 {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0 0 0.6rem;
    color: var(--fg);
  }
  h3 a { color: inherit; text-decoration: none; }
  h3 a:hover { color: var(--accent); }
  .summary { margin: 0 0 0.6rem; color: var(--fg); line-height: 1.55; max-width: 40rem; }
  .more { margin: 0; font-family: var(--font-sans); font-size: 0.9375rem; }
  .more a, .links a, .facts a { color: var(--accent); }

  .release-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 2rem; }
  .lead-item { padding: 0; }

  .mk-sub {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
    color: var(--fg);
    margin: 2rem 0 0.75rem;
  }
  .note { color: var(--muted); font-size: 0.9375rem; line-height: 1.55; }
  .note code { font-family: var(--font-mono); font-size: 0.85em; }
  .bio-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 1.1rem 0 0.35rem;
  }
  .bio { margin: 0 0 0.75rem; line-height: 1.65; color: var(--fg); max-width: 42rem; }

  .assets { display: flex; flex-wrap: wrap; gap: 1.5rem; margin: 0.5rem 0; }
  .asset { margin: 0; max-width: 320px; }
  .asset img { display: block; width: 100%; height: auto; border: 1px solid var(--border); border-radius: 6px; }
  .asset figcaption {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .asset figcaption a { color: var(--accent); }
  .placeholder-box {
    width: 320px;
    height: 168px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed var(--border);
    border-radius: 6px;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.8rem;
    background: repeating-linear-gradient(45deg, transparent, transparent 10px, color-mix(in oklab, var(--border) 30%, transparent) 10px, color-mix(in oklab, var(--border) 30%, transparent) 20px);
  }
  .flag {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.4;
  }

  .quotes { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.25rem; }
  .quotes blockquote {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-style: italic;
    line-height: 1.45;
    color: var(--fg);
    max-width: 42rem;
  }
  .quotes cite { display: block; margin-top: 0.4rem; font-style: normal; font-family: var(--font-mono); font-size: 0.75rem; color: var(--muted); }

  .topics, .links { margin: 0; padding-left: 1.1rem; line-height: 1.7; color: var(--fg); }
  .topics li, .links li { margin: 0.1rem 0; }
  .links { list-style: none; padding-left: 0; }

  .lead-line { font-size: 1.0625rem; line-height: 1.55; color: var(--fg); margin: 0 0 1rem; max-width: 40rem; }

  .facts { margin: 0; display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1.5rem; }
  .facts dt { font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
  .facts dd { margin: 0; color: var(--fg); }
</style>
