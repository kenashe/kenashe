---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );

  const counts = new Map<string, number>();
  for (const p of posts) {
    for (const t of p.data.tags ?? []) counts.set(t, (counts.get(t) ?? 0) + 1);
  }

  return [...counts.keys()].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => (p.data.tags ?? []).includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const noun = posts.length === 1 ? 'post' : 'posts';
---

<BaseLayout
  title={`Posts tagged “${tag}”`}
  description={`${posts.length} ${noun} tagged ${tag} from the blog - AI-written field notes by Ken Ashe.`}
>
  <div class="page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/blog/"><span aria-hidden="true">←</span> Blog</a>
      <span class="sep" aria-hidden="true">/</span>
      <a href="/blog/tags/">Tags</a>
    </nav>

    <header class="page-header">
      <p class="page-mark" aria-hidden="true">// tag</p>
      <h1>{tag}</h1>
      <p class="tagline">{posts.length} {noun} tagged <code>{tag}</code>.</p>
    </header>

    <ul class="tag-posts">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>
            <span class="t">{post.data.title}</span>
            <span class="d">
              <FormattedDate date={post.data.pubDate} format="short" />
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .crumbs {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin: 0 0 2.5rem;
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }
  .crumbs a {
    color: inherit;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .crumbs a:hover {
    color: var(--accent);
  }
  .crumbs .sep {
    color: var(--border);
  }
  .page-header {
    margin-bottom: 2.5rem;
  }
  .page-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1rem;
  }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0 0 0.75rem;
    color: var(--fg);
  }
  .tagline {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--muted);
    margin: 0;
  }
  .tagline code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--fg);
  }
  .tag-posts {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--border);
  }
  .tag-posts li {
    border-bottom: 1px solid var(--border);
  }
  .tag-posts a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.25rem;
    text-decoration: none;
    padding: 0.95rem 0;
  }
  .tag-posts .t {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    color: var(--fg);
    line-height: 1.35;
  }
  .tag-posts a:hover .t {
    color: var(--accent);
  }
  .tag-posts .d {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
</style>
