---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { NEWSLETTER_URL } from '../../consts';

const all = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const posts = all.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Tag counts, descending by count, then alpha.
const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);
---

<BaseLayout
  title="AI Blog"
  description="AI and digital marketing notes — synthesized daily."
>
  <div class="page">
    <header class="page-header">
      <h1>AI Blog</h1>
      <p class="tagline">AI and digital marketing notes — synthesized daily.</p>
      <p class="rss">
        <a href="/rss.xml">RSS →</a>
      </p>
      <p class="lede">
        Working notes on AI and digital marketing — synthesized daily from research, curated and
        edited. For long-form essays in my own voice, see{' '}
        <a href={NEWSLETTER_URL} target="_blank" rel="noopener">Newsletter</a>.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="empty">New writing coming soon.</p>
      ) : (
        <>
          {tags.length > 0 && (
            <nav class="filters" aria-label="Filter posts by tag">
              <button
                class="filter"
                type="button"
                data-filter="__all__"
                data-active
                aria-pressed="true"
              >
                All <span class="count">({posts.length})</span>
              </button>
              {tags.map(([tag, count]) => (
                <button class="filter" type="button" data-filter={tag} aria-pressed="false">
                  {tag} <span class="count">({count})</span>
                </button>
              ))}
            </nav>
          )}

          <p class="sr-only" id="filter-status" role="status" aria-live="polite">
            Showing {posts.length} posts.
          </p>

          <ul class="grid">
            {posts.map((post) => {
              const cls = post.data.image ? 'card has-image' : 'card no-image';
              const tagStr = (post.data.tags ?? []).join('|||');
              return (
                <li class="grid-cell" data-tags={tagStr}>
                  <a href={`/blog/${post.id}/`} class={cls}>
                    <article>
                      {post.data.image ? (
                        <div class="card-image">
                          <Image
                            src={post.data.image.src}
                            alt={post.data.image.alt}
                            widths={[400, 700, 1000]}
                            sizes="(min-width: 768px) 420px, 100vw"
                          />
                        </div>
                      ) : null}
                      <div class="card-body">
                        <p class="card-meta">
                          <FormattedDate date={post.data.pubDate} format="short" />
                          {post.data.draft && (
                            <>
                              <span aria-hidden="true"> · </span>
                              <span class="draft-tag">Draft</span>
                            </>
                          )}
                        </p>
                        <h3 class="card-title">{post.data.title}</h3>
                        {post.data.description && (
                          <p class="card-desc">{post.data.description}</p>
                        )}
                        {post.data.tags?.length > 0 && (
                          <ul class="card-tags" aria-label="Tags">
                            {post.data.tags.map((t) => (
                              <li>#{t}</li>
                            ))}
                          </ul>
                        )}
                      </div>
                    </article>
                  </a>
                </li>
              );
            })}
          </ul>
        </>
      )
    }
  </div>
</BaseLayout>

<script>
  const ALL = '__all__';
  const filters = document.querySelectorAll<HTMLButtonElement>('.filters .filter');
  const cells = document.querySelectorAll<HTMLElement>('.grid > .grid-cell');
  const status = document.getElementById('filter-status');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-filter') ?? ALL;
      filters.forEach((b) => {
        b.removeAttribute('data-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.setAttribute('data-active', '');
      btn.setAttribute('aria-pressed', 'true');

      let shown = 0;
      cells.forEach((cell) => {
        const cellTags = (cell.getAttribute('data-tags') ?? '')
          .split('|||')
          .map((t) => t.trim())
          .filter(Boolean);
        const show = tag === ALL || cellTags.includes(tag);
        cell.hidden = !show;
        if (show) shown += 1;
      });

      if (status) {
        const noun = shown === 1 ? 'post' : 'posts';
        status.textContent =
          tag === ALL
            ? `Showing ${shown} ${noun}.`
            : `Showing ${shown} ${noun} tagged ${tag}.`;
      }
    });
  });
</script>

<style>
  .page {
    max-width: 60rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 0;
  }
  .page-header {
    margin-bottom: 2.5rem;
    max-width: 40rem;
  }
  .page-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }
  .tagline {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--muted);
    font-size: 1.125rem;
    margin: 0;
  }
  .rss {
    margin: 0.75rem 0 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
  }
  .rss a {
    color: var(--muted);
    text-decoration: none;
  }
  .rss a:hover {
    color: var(--fg);
  }
  .lede {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 1.25rem 0 0;
  }
  .lede a {
    color: inherit;
  }

  .empty {
    color: var(--muted);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.125rem;
    padding: 2rem 0;
  }

  /* Tag filter */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin: 0 0 2.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--rule);
  }
  .filter {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0.2rem 0;
    font: inherit;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }
  .filter:hover {
    color: var(--fg);
  }
  .filter[data-active] {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
  .filter .count {
    color: var(--muted);
    font-weight: 400;
    margin-left: 0.15em;
  }
  .filter[data-active] .count {
    color: var(--muted);
  }

  /* Card grid */
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 2.5rem 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 2px;
    transition: opacity 150ms ease;
  }
  .card:hover {
    opacity: 0.92;
  }
  .card article {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--subtle);
    border-radius: 2px;
    margin-bottom: 1rem;
  }
  .card-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card.no-image {
    border: 1px solid var(--rule);
    padding: 1.5rem;
    transition: border-color 150ms ease;
  }
  .card.no-image:hover {
    border-color: var(--fg);
    opacity: 1;
  }
  .card.no-image .card-body {
    padding: 0;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .card-meta {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .draft-tag {
    color: var(--muted);
  }
  .card-title {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.25;
    color: var(--fg);
    margin: 0;
  }
  .card-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tags {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--muted);
  }
  .card-tags li {
    letter-spacing: 0.02em;
  }
</style>
