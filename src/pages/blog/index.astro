---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { NEWSLETTER_URL } from '../../consts';

const all = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const posts = all.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Tag counts, descending by count, then alpha.
const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);

// Show the most-used tags inline; the long tail collapses behind a toggle and
// lives on dedicated, crawlable pages at /blog/tags/<tag>/.
const TOP_TAGS = 14;
const primaryTags = tags.slice(0, TOP_TAGS);
const extraTags = tags.slice(TOP_TAGS);
---

<BaseLayout
  title="The Lab"
  description="AI-written field notes from a marketer building with AI in public. Every post clears a 40-point quality gate and often a human review."
>
  <div class="page">
    <header class="page-header">
      <p class="page-mark" aria-hidden="true">// the lab</p>
      <h1>The Lab</h1>
      <p class="tagline">AI-written field notes from a marketer building with AI in public.</p>
      <p class="lede">
        Every post here is researched, drafted, and edited by an automated AI pipeline, then
        run through a 40-point quality gate, and often a human review (me), before it ships.
        Half build log, half running notes on what's working, what's breaking, and what's worth
        stealing. For long-form essays in my own voice, see the{' '}
        <a href={NEWSLETTER_URL} target="_blank" rel="noopener">Newsletter ↗</a>.
      </p>
      <p class="rss">
        <a href="/rss.xml">RSS →</a>
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="empty">New writing coming soon.</p>
      ) : (
        <>
          {tags.length > 0 && (
            <nav class="filters" aria-label="Filter posts by tag">
              <button
                class="filter"
                type="button"
                data-filter="__all__"
                data-active
                aria-pressed="true"
              >
                All <span class="count">({posts.length})</span>
              </button>
              {primaryTags.map(([tag, count]) => (
                <button class="filter" type="button" data-filter={tag} aria-pressed="false">
                  {tag} <span class="count">({count})</span>
                </button>
              ))}
              {extraTags.map(([tag, count]) => (
                <button
                  class="filter filter-extra"
                  type="button"
                  data-filter={tag}
                  aria-pressed="false"
                  hidden
                >
                  {tag} <span class="count">({count})</span>
                </button>
              ))}
              {extraTags.length > 0 && (
                <button class="tag-more" type="button" id="tag-more" aria-expanded="false">
                  +{extraTags.length} more
                </button>
              )}
              <a class="tag-alltags" href="/blog/tags/">All tags →</a>
            </nav>
          )}

          <p class="sr-only" id="filter-status" role="status" aria-live="polite">
            Showing {posts.length} posts.
          </p>

          <ul class="grid">
            {posts.map((post) => {
              const cls = post.data.image ? 'card has-image' : 'card no-image';
              const tagStr = (post.data.tags ?? []).join('|||');
              return (
                <li class="grid-cell" data-tags={tagStr}>
                  <a href={`/blog/${post.id}/`} class={cls}>
                    <article>
                      {post.data.image ? (
                        <div class="card-image">
                          <Image
                            src={post.data.image.src}
                            alt={post.data.image.alt}
                            widths={[400, 700, 1000]}
                            sizes="(min-width: 768px) 420px, 100vw"
                          />
                        </div>
                      ) : null}
                      <div class="card-body">
                        <p class="card-meta">
                          <FormattedDate date={post.data.pubDate} format="short" />
                          {post.data.draft && (
                            <>
                              <span aria-hidden="true"> · </span>
                              <span class="draft-tag">Draft</span>
                            </>
                          )}
                        </p>
                        <h3 class="card-title">{post.data.title}</h3>
                        {post.data.description && (
                          <p class="card-desc">{post.data.description}</p>
                        )}
                        {post.data.tags?.length > 0 && (
                          <ul class="card-tags" aria-label="Tags">
                            {post.data.tags.map((t) => (
                              <li>{t}</li>
                            ))}
                          </ul>
                        )}
                      </div>
                    </article>
                  </a>
                </li>
              );
            })}
          </ul>
        </>
      )
    }
  </div>
</BaseLayout>

<script>
  const ALL = '__all__';
  const filters = document.querySelectorAll<HTMLButtonElement>('.filters .filter');
  const cells = document.querySelectorAll<HTMLElement>('.grid > .grid-cell');
  const status = document.getElementById('filter-status');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-filter') ?? ALL;
      filters.forEach((b) => {
        b.removeAttribute('data-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.setAttribute('data-active', '');
      btn.setAttribute('aria-pressed', 'true');

      let shown = 0;
      cells.forEach((cell) => {
        const cellTags = (cell.getAttribute('data-tags') ?? '')
          .split('|||')
          .map((t) => t.trim())
          .filter(Boolean);
        const show = tag === ALL || cellTags.includes(tag);
        cell.hidden = !show;
        if (show) shown += 1;
      });

      if (status) {
        const noun = shown === 1 ? 'post' : 'posts';
        status.textContent =
          tag === ALL
            ? `Showing ${shown} ${noun}.`
            : `Showing ${shown} ${noun} tagged ${tag}.`;
      }
    });
  });

  // Collapse the long tail of tag filters behind a toggle (progressive
  // enhancement — the full set also lives at /blog/tags/).
  const moreBtn = document.getElementById('tag-more');
  if (moreBtn) {
    const extras = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.filters .filter-extra'),
    );
    moreBtn.addEventListener('click', () => {
      const expanded = moreBtn.getAttribute('aria-expanded') === 'true';
      extras.forEach((el) => {
        el.hidden = expanded;
      });
      moreBtn.setAttribute('aria-expanded', String(!expanded));
      moreBtn.textContent = expanded ? `+${extras.length} more` : 'Show fewer';
    });
  }
</script>

<style>
  .page {
    max-width: 60rem;
    margin: 0 auto;
    padding: 5rem 1.5rem 0;
  }
  .page-header {
    margin-bottom: 4rem;
    max-width: 42rem;
  }
  .page-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 8vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0 0 1.25rem;
    color: var(--fg);
  }
  .tagline {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.45;
    color: var(--fg);
    margin: 0 0 1.5rem;
    max-width: 36rem;
  }
  .lede {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted);
    margin: 0 0 1.75rem;
    max-width: 38rem;
  }
  .lede a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--border);
    text-underline-offset: 0.18em;
    transition:
      color 150ms ease,
      text-decoration-color 150ms ease;
  }
  .lede a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }
  .rss {
    margin: 0;
  }
  .rss a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }
  .rss a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .empty {
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    padding: 2rem 0;
  }

  /* Tag filter */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 1rem;
    margin: 0 0 1.25rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
  }
  .filter {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0.12rem 0;
    font: inherit;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }
  .filter:hover {
    color: var(--fg);
  }
  .filter[data-active] {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .filter .count {
    color: var(--muted);
    font-weight: 400;
    margin-left: 0.25em;
    font-variant-numeric: tabular-nums;
  }
  .filter[data-active] .count {
    color: color-mix(in oklab, var(--accent) 65%, var(--muted));
  }
  .filter-extra[hidden] {
    display: none;
  }
  .tag-more,
  .tag-alltags {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0.12rem 0;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    cursor: pointer;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }
  .tag-more:hover {
    color: var(--fg);
  }
  .tag-alltags {
    color: color-mix(in oklab, var(--accent) 80%, var(--muted));
  }
  .tag-alltags:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* Card grid */
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .card {
    display: block;
    text-decoration: none;
    color: inherit;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.5rem;
    height: 100%;
    transition:
      border-color 200ms ease,
      transform 200ms ease;
  }
  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .card article {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg);
    border-radius: 4px;
    border: 1px solid var(--border);
    margin: -0.25rem 0 1.1rem;
  }
  .card-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }
  .card-meta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .draft-tag {
    color: var(--accent);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--fg);
    margin: 0;
  }
  .card-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-tags {
    list-style: none;
    margin: auto 0 0;
    padding: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .card-tags li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.22rem 0.5rem;
    letter-spacing: 0.02em;
  }
</style>
