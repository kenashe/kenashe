---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, AUTHOR, SOCIAL } from '../consts';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: AUTHOR,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  sameAs: SOCIAL.filter((s) => s.href.startsWith('http')).map((s) => s.href),
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE_URL}/about/` },
};
---

<BaseLayout title="About" description={`About ${SITE_TITLE} — ${SITE_DESCRIPTION}`}>
  <JsonLd slot="jsonld" data={personSchema} />

  <article class="page">
    <header class="page-header">
      <h1>About</h1>
    </header>

    <div class="prose">
      {/* TODO: Long-form bio. A few paragraphs covering background, what you build, and what you're working on now. */}
      <p>
        Placeholder. Replace this with two or three paragraphs of long-form bio. The first
        paragraph might cover who you are and the work you do day to day. The second can talk
        about what you're building with AI and why. A third can be more personal — interests,
        location, what drew you here.
      </p>

      <p>
        {/* TODO: replace */}
        Another placeholder paragraph. Use this space to be specific about the kinds of problems
        you take on, the customers you serve, and the tools or stacks you reach for. Specifics
        beat generalities — name companies, name products, name results.
      </p>

      <h2>Now</h2>
      <p>
        {/* TODO: a "now" section — current focus, à la nownownow.com */}
        What you're focused on right now. One or two sentences.
      </p>

      <h2>Elsewhere</h2>
      <ul>
        {
          SOCIAL.map((s) => (
            <li>
              <a href={s.href} rel={s.href.startsWith('http') ? 'me noopener' : undefined}>
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </article>
</BaseLayout>

<style>
  .page {
    max-width: 40rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 0;
  }
  .page-header {
    margin-bottom: 2.5rem;
  }
  .page-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
  }
</style>
