---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { personKenAshe } from '../data/schema';

const description =
  'Ken Ashe is an AI application builder, CPA, and PMP, building with AI in public.';

// Credibility cards (spec §14): the four facets. "Digital marketer" lives here,
// demoted from the trust line where the preferred positioning leads.
const hats = [
  {
    label: 'CPA',
    body: 'Evidence over vibes. A CPA reflex for numbers, controls, and proof, applied to every tool and workflow I adopt.',
  },
  {
    label: 'PMP / Operator',
    body: 'Most of my career in project management: scoping, sequencing, and actually shipping real deliverables on real timelines.',
  },
  {
    label: 'Digital marketer',
    body: 'A boutique marketing firm. Affiliate, SEO, and conversion across channels, with AI taking more of the lift each month.',
  },
  {
    label: 'AI builder',
    body: 'The application layer: agents, automations, AI-assisted websites, and workflow systems, built from existing models and tools.',
  },
];

const pillars = ['Agents', 'Automations', 'AI-assisted websites', 'Workflow systems'];

// Real, day-to-day stack (kept current): the models I prompt, and the
// tools/platforms I build with.
const models = ['Claude', 'ChatGPT', 'Gemini', 'Grok', 'DeepSeek'];
const tools = [
  'Claude Code',
  'Codex',
  'n8n',
  'HyperAgent',
  'Hermes',
  'ElevenLabs',
  'Higgsfield',
  'OpenRouter',
];

// Earned credentials + training. The Claude certification is an intentional
// placeholder (spec §17/§18): named but clearly not yet earned.
const credentials = [
  { name: 'Certified Public Accountant (CPA)', issuer: 'Active' },
  { name: 'Project Management Professional (PMP)', issuer: 'Active' },
  { name: 'AI Prototyping for Product Managers', issuer: 'Maven' },
  { name: 'How to Scale a Business With Agentic Workflows', issuer: 'AI Build Lab' },
  {
    name: 'Agentic AI Certification: Claude Code, Hermes Agent & Evals for PMs',
    issuer: 'AI Build Lab',
  },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfilePage',
      '@id': 'https://kenashe.ai/about/#profile',
      url: 'https://kenashe.ai/about/',
      name: 'About Ken Ashe',
      mainEntity: { '@id': 'https://kenashe.ai/#ken-ashe' },
      about: { '@id': 'https://kenashe.ai/#ken-ashe' },
      isPartOf: { '@id': 'https://kenashe.ai/#website' },
      inLanguage: 'en-US',
    },
    {
      '@type': 'WebSite',
      '@id': 'https://kenashe.ai/#website',
      name: 'KenAshe.ai',
      url: 'https://kenashe.ai/',
      sameAs: ['https://www.linkedin.com/company/kenashe-ai'],
      creator: { '@id': 'https://kenashe.ai/#ken-ashe' },
      publisher: { '@id': 'https://kenashe.ai/#ken-ashe' },
      inLanguage: 'en-US',
    },
    personKenAshe,
  ],
};
---

<BaseLayout
  title="About"
  description={description}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'About', path: '/about/' },
  ]}
>
  <JsonLd slot="jsonld" data={aboutSchema} />

  <article class="page">
    <header class="page-header">
      <p class="page-mark" aria-hidden="true">// about</p>
      <h1>About</h1>
      <p class="lead">I build practical AI applications, then document the receipts in public.</p>
      <p class="lead-sub">
        Agents, automations, AI-assisted websites, and workflow systems, under my real name. No
        hype, no doom.
      </p>
    </header>

    <section class="block" aria-labelledby="bring-h">
      <h2 id="bring-h" class="group-heading">What I bring</h2>
      <ul class="hats">
        {
          hats.map((h) => (
            <li class="hat">
              <h3 class="hat-label">{h.label}</h3>
              <p class="hat-body">{h.body}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="block" aria-labelledby="thesis-h">
      <h2 id="thesis-h" class="group-heading">Thesis</h2>
      <p class="thesis">
        The public conversation about AI is stuck between people overselling it and people
        catastrophizing it, and almost nobody is occupying the calm middle. I'd like to. I think
        AI is one of the most useful tools we've built in a long time, and I'd rather show what's
        actually working than argue about what might happen. Receipts over rhetoric.
      </p>
    </section>

    <section class="block" aria-labelledby="work-h">
      <h2 id="work-h" class="group-heading">How I work</h2>
      <p class="prose-p">
        I work at the AI application layer: turning existing models, APIs, coding tools, and
        automation platforms into useful systems. You don't need to train models or wire up
        infrastructure to make AI do real work. You need to use it well, and prove it.
      </p>
      <ul class="pillars" aria-label="What I build">
        {pillars.map((p) => <li>{p}</li>)}
      </ul>
      <p class="prose-p">
        This site is one of those projects, built end-to-end with Claude Code and reviewed by
        Codex, as a way to learn the stack in public. It's a sandbox and I treat it like one.
        Things break here; that's fine. What I learn feeds back into the real client work I do as
        a marketer.
      </p>
    </section>

    <section class="block" aria-labelledby="stack-h">
      <h2 id="stack-h" class="group-heading">Stack</h2>
      <div class="stack-group">
        <p class="stack-label">Models</p>
        <ul class="stack" aria-label="Models">
          {models.map((s) => <li>{s}</li>)}
        </ul>
      </div>
      <div class="stack-group">
        <p class="stack-label">Tools &amp; platforms</p>
        <ul class="stack" aria-label="Tools and platforms">
          {tools.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    </section>

    <section class="block" aria-labelledby="creds-h">
      <h2 id="creds-h" class="group-heading">Credentials</h2>
      <ul class="creds">
        {
          credentials.map((c) => (
            <li class="cred">
              <span class="cred-name">{c.name}</span>
              <span class="cred-issuer">{c.issuer}</span>
            </li>
          ))
        }
        <li class="cred cred-pending">
          <span class="cred-name">Claude Certified Architect, Foundations</span>
          <span class="cred-issuer">Planned</span>
        </li>
      </ul>
    </section>

    <p class="closing">
      Ken Ashe is an AI application builder, CPA, and PMP building with AI in public, and the
      founder of Lucky Domains, a domain acquisition, brokerage, and SEO services company.
    </p>
  </article>
</BaseLayout>

<style>
  .page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .page-header {
    margin-bottom: 3.5rem;
  }
  .page-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0 0 1.5rem;
    color: var(--fg);
  }
  .lead {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 2.6vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--fg);
    margin: 0 0 1rem;
    max-width: 32ch;
  }
  .lead-sub {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.6vw, 1.2rem);
    line-height: 1.5;
    color: var(--muted);
    margin: 0;
    max-width: 38rem;
  }

  .block {
    margin-bottom: 3rem;
  }
  .group-heading {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }

  /* Credibility cards */
  .hats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  .hat {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.4rem 1.4rem 1.25rem;
  }
  .hat-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }
  .hat-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--fg);
    margin: 0;
  }

  /* Thesis */
  .thesis {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    font-weight: 500;
    line-height: 1.6;
    color: var(--fg);
    margin: 0;
    max-width: 42rem;
  }

  /* Prose + pillars */
  .prose-p {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--fg);
    margin: 0 0 1.25rem;
    max-width: 40rem;
  }
  .prose-p:last-child {
    margin-bottom: 0;
  }
  .pillars {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pillars li {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--fg);
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
  }

  /* Stack chips */
  .stack-group + .stack-group {
    margin-top: 1.1rem;
  }
  .stack-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.55rem;
  }
  .stack {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .stack li {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3rem 0.6rem;
  }

  /* Credentials list */
  .creds {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cred {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .cred-name {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--fg);
  }
  .cred-issuer {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    flex-shrink: 0;
  }
  .cred-pending {
    opacity: 0.7;
  }
  .cred-pending .cred-name {
    color: var(--muted);
  }
  .cred-pending .cred-issuer {
    color: var(--accent);
    border: 1px dashed color-mix(in oklab, var(--accent) 45%, var(--border));
    border-radius: 999px;
    padding: 0.15rem 0.5rem;
  }

  .closing {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 1rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    max-width: 42rem;
  }
</style>
