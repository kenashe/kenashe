---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BuildCard from '../components/BuildCard.astro';
import { fetchLatestSubstackPosts } from '../utils/substack';
import {
  SITE_DESCRIPTION,
  SITE_URL,
  AUTHOR,
  NEWSLETTER_URL,
  SUBSTACK_RSS_URL,
  SOCIAL,
} from '../consts';
import { projects } from '../data/builds';

// Newsletter: real Substack posts at build time.
// - If the fetch succeeds, render real posts.
// - In dev, when the fetch returns nothing, render local placeholders so the
//   section has visual weight while iterating.
// - In prod, when the fetch returns nothing, render a single empty-state row.
//   We never ship placeholder copy to production.
const substackPosts = await fetchLatestSubstackPosts(SUBSTACK_RSS_URL, 3);
const newsletterPlaceholders: { title: string; href: string; date: string }[] = [
  { title: 'Placeholder newsletter post one', href: NEWSLETTER_URL, date: '2026' },
  { title: 'Placeholder newsletter post two', href: NEWSLETTER_URL, date: '2026' },
  { title: 'Placeholder newsletter post three', href: NEWSLETTER_URL, date: '2026' },
];

// AI Blog: pulled from the blog content collection, sorted by pubDate desc.
const allNotes = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const notes = allNotes
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const liveProjects = projects.filter((p) => p.status === 'LIVE');

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: AUTHOR,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  sameAs: SOCIAL.filter((s) => s.href.startsWith('http')).map((s) => s.href),
};
---

<BaseLayout description={SITE_DESCRIPTION}>
  <JsonLd slot="jsonld" data={personSchema} />

  <article class="home">
    <header class="hero">
      <h1 class="hero-headline">AI Optimist</h1>
      <p class="hero-positioning">
        An operator's case for building with AI. Proven in public. No hype, no doom.
      </p>
      <p class="hero-status">
        <span class="hero-status-prefix" aria-hidden="true">//&nbsp;</span>digital marketer ·
        CPA · building with AI in public
      </p>
      <div class="hero-ctas">
        <a class="cta cta-primary" href={NEWSLETTER_URL} target="_blank" rel="noopener">
          Subscribe
          <span aria-hidden="true">→</span>
        </a>
        <a class="cta cta-ghost" href="/blog/">Read the latest</a>
      </div>
    </header>

    <section aria-labelledby="building-heading" class="block">
      <div class="block-head">
        <h2 id="building-heading">Building</h2>
        <a href="/building/" class="block-link">All builds →</a>
      </div>
      <ul class="receipts">
        {liveProjects.map((p) => <BuildCard project={p} />)}
      </ul>
    </section>

    <section aria-labelledby="principles-heading" class="principles">
      <h2 id="principles-heading" class="sr-only">Principles</h2>
      <p class="principles-mark" aria-hidden="true">//</p>
      <p class="principle">No hype.</p>
      <p class="principle">No doom.</p>
      <p class="principle">Receipts only.</p>
    </section>

    <section aria-labelledby="newsletter-heading" class="block">
      <div class="block-head">
        <h2 id="newsletter-heading">Newsletter</h2>
        <a href={NEWSLETTER_URL} class="block-link" target="_blank" rel="noopener">Subscribe →</a>
      </div>
      <ul class="post-list">
        {
          substackPosts.length > 0 ? (
            substackPosts.map((post) => (
              <li>
                <a href={post.link} target="_blank" rel="noopener">
                  <span class="post-title">{post.title}</span>
                  <span class="post-date">
                    <FormattedDate date={post.pubDate} format="short" />
                  </span>
                </a>
              </li>
            ))
          ) : import.meta.env.DEV ? (
            newsletterPlaceholders.map((post) => (
              <li>
                <a href={post.href} target="_blank" rel="noopener">
                  <span class="post-title">{post.title}</span>
                  <span class="post-date">{post.date}</span>
                </a>
              </li>
            ))
          ) : (
            <li class="newsletter-empty">
              <p class="post-placeholder">
                <span class="post-title">Latest newsletter posts will appear here.</span>
                <span class="post-date">—</span>
              </p>
            </li>
          )
        }
      </ul>
    </section>

    <section aria-labelledby="thelab-heading" class="block">
      <div class="block-head">
        <h2 id="thelab-heading">The Lab</h2>
        <a href="/blog/" class="block-link">All posts →</a>
      </div>
      <ul class="post-list">
        {
          notes.length > 0 ? (
            notes.map((note) => (
              <li>
                <a href={`/blog/${note.id}/`}>
                  <span class="post-title">
                    {note.data.draft && <span class="draft-tag">[Draft]</span>}
                    {note.data.title}
                  </span>
                  <span class="post-date">
                    <FormattedDate date={note.data.pubDate} format="short" />
                  </span>
                </a>
              </li>
            ))
          ) : (
            <>
              <li>
                <span class="post-placeholder">
                  <span class="post-title">Note placeholder one</span>
                  <span class="post-date">—</span>
                </span>
              </li>
              <li>
                <span class="post-placeholder">
                  <span class="post-title">Note placeholder two</span>
                  <span class="post-date">—</span>
                </span>
              </li>
              <li>
                <span class="post-placeholder">
                  <span class="post-title">Note placeholder three</span>
                  <span class="post-date">—</span>
                </span>
              </li>
            </>
          )
        }
      </ul>
    </section>

  </article>
</BaseLayout>

<style>
  .home {
    max-width: 52rem;
    margin: 0 auto;
    padding: 5rem 1.5rem 0;
  }

  .hero {
    margin-bottom: 6rem;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(3rem, 11vw, 7.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin: 0 0 1.5rem;
    color: var(--fg);
  }
  .hero-positioning {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.8vw, 1.375rem);
    line-height: 1.45;
    color: var(--fg);
    margin: 0 0 1.5rem;
    max-width: 38rem;
  }
  .hero-status {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    letter-spacing: 0.02em;
    margin: 0 0 2.5rem;
  }
  .hero-status-prefix {
    color: var(--accent);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.7rem 1.15rem;
    border-radius: 4px;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      border-color 150ms ease;
  }
  .cta-primary {
    background-color: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
  }
  .cta-primary:hover {
    background-color: var(--fg);
    border-color: var(--fg);
    color: var(--bg);
  }
  .cta-ghost {
    background-color: transparent;
    color: var(--fg);
    border: 1px solid var(--border);
  }
  .cta-ghost:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .block {
    margin-top: 3.5rem;
  }
  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .block h2 {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .block-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted);
    text-decoration: none;
  }
  .block-link:hover {
    color: var(--fg);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li {
    margin-bottom: 0.25rem;
  }
  .post-list a,
  .post-placeholder {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    text-decoration: none;
    padding: 0.4rem 0;
  }
  .post-title {
    font-size: 1.0625rem;
    flex: 1;
  }
  .post-list a:hover .post-title {
    color: var(--accent);
  }
  .post-date {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .post-placeholder {
    color: var(--muted);
    cursor: default;
    margin: 0;
  }
  .draft-tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-right: 0.4rem;
  }

  .receipts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  .principles {
    margin: 5rem 0 4rem;
    padding: 3.75rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .principles-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  .principle {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 7vw, 4.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--fg);
    margin: 0;
  }
  .principle + .principle {
    margin-top: 0.3rem;
  }
</style>
