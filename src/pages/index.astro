---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { SITE_DESCRIPTION } from '../consts';
import { projects, type Project } from '../data/builds';
import { personKenAshe } from '../data/schema';

// Homepage = media landing page (spec v2.2 §4). Not a blog index; a polished,
// static-but-animated showcase. No live API-powered widgets by design.
// Flagship-dependent sections (Summer Build Series §4.4, Latest build updates
// §4.6) are intentionally omitted until the flagship pages + embedded build
// logs exist (Phase 2/3).

// Media credibility strip (§4.2): how media can use Ken. Topics mirror the
// Newsroom speaking-topics list verbatim so the site states one consistent set.
const availableFor = ['Media interviews', 'Podcast appearances', 'Speaking', 'AI commentary'];
const mediaTopics = [
  'Building with AI in public',
  'Practical AI for operators and non-engineers',
  'AI agents and workflow automation',
  'AI-assisted website development',
  'AI coding tools in real projects',
  'Marketing operations automation',
];

// What I build (§4.3): the four pillars of the "AI application builder" umbrella (§1).
const pillars = [
  {
    name: 'Agents',
    body: 'Task-scoped agents that research, draft, qualify, and act, wired to real tools and data rather than demos.',
  },
  {
    name: 'Automations',
    body: 'Scheduled and event-driven pipelines that run on their own and do real work without me starting them.',
  },
  {
    name: 'AI-assisted websites',
    body: 'Sites designed, built, and shipped with AI coding tools, then reviewed, deployed, and live on real domains.',
  },
  {
    name: 'Workflow applications',
    body: 'Internal tools and multi-step systems that turn a manual process into something repeatable and fast.',
  },
];

// Featured Projects (§4.5): a small, curated selection surfaced from the Projects
// page. Shipped-only proof, seeded from builds.ts (§6). Exposed-monetization
// properties stay off the homepage, so the geo-targeted affiliate site is
// excluded per the card rule. The full tiered Projects rebuild (§5) is a later
// PR; here we reuse the same real receipts, no fabrication, never clickable.
const FEATURED_TITLES = [
  'Six-agent email response team',
  'Daily email to myself',
  'Sir Pitches-a-lot',
  'kenashe.ai',
];
const featured = FEATURED_TITLES.map((t) => projects.find((p) => p.title === t)).filter(
  (p): p is Project => p !== undefined,
);

// Newsroom preview (§4.7): the latest real announcement. Mirrors the live
// Newsroom index; we link to the release, we do not restate or fabricate it.
const latestNews = {
  date: 'June 24, 2026',
  kicker: 'Announcement',
  title:
    'KenAshe.ai Launches as a Public Build Log for Practical AI Projects and Website Development',
  href: '/news/site-launch/',
  summary:
    'Personal site from AI operator Ken Ashe documents AI builds, website development, automation experiments, and the process of building with AI in public.',
};

// Entity schema - preserved verbatim from the prior homepage (load-bearing).
const homeSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://kenashe.ai/#website',
      name: 'KenAshe.ai',
      url: 'https://kenashe.ai/',
      sameAs: ['https://www.linkedin.com/company/kenashe-ai'],
      description: 'Personal publication and public AI build log from Ken Ashe.',
      creator: { '@id': 'https://kenashe.ai/#ken-ashe' },
      publisher: { '@id': 'https://kenashe.ai/#ken-ashe' },
      mainEntity: { '@id': 'https://kenashe.ai/#ken-ashe' },
      inLanguage: 'en-US',
    },
    personKenAshe,
  ],
};
---

<BaseLayout description={SITE_DESCRIPTION}>
  <JsonLd slot="jsonld" data={homeSchema} />

  <div class="motif-bar" aria-hidden="true"></div>

  <!-- 1. HERO -->
  <header class="hero">
    <div class="section-inner hero-inner">
      <p class="eyebrow">KenAshe.ai</p>
      <h1 class="hero-headline">Building with AI in Public</h1>
      <p class="hero-sub">
        I'm Ken Ashe, an AI application builder documenting real systems across agents,
        automations, AI-assisted websites, and marketing workflows, including what shipped, what
        broke, and what others can learn.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/projects/">
          View Projects
          <span aria-hidden="true">→</span>
        </a>
        <a class="btn btn-ghost" href="/newsroom/">Visit the Newsroom</a>
      </div>
      <p class="trust">AI application builder · CPA · PMP · Building with AI in public</p>
    </div>
  </header>

  <!-- 2. MEDIA CREDIBILITY STRIP -->
  <section class="media-strip" aria-labelledby="media-h">
    <div class="section-inner">
      <p class="eyebrow eyebrow-light">For media</p>
      <h2 id="media-h" class="media-title">
        Available for interviews, podcasts, speaking, and AI commentary.
      </h2>
      <ul class="avail-list" aria-label="Available for">
        {availableFor.map((a) => <li>{a}</li>)}
      </ul>
      <p class="topics-label">Topics</p>
      <ul class="topic-list" aria-label="Interview topics">
        {mediaTopics.map((t) => <li>{t}</li>)}
      </ul>
      <p class="media-cta">
        <a href="/newsroom/#available-for-comment">Newsroom &amp; media kit →</a>
      </p>
    </div>
  </section>

  <!-- 3. WHAT I BUILD -->
  <section class="block" aria-labelledby="build-h">
    <div class="section-inner">
      <p class="eyebrow">What I build</p>
      <h2 id="build-h" class="block-title">Practical AI applications, four ways.</h2>
      <ul class="pillars">
        {
          pillars.map((p) => (
            <li class="card pillar">
              <h3 class="pillar-name">{p.name}</h3>
              <p class="pillar-body">{p.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 5. FEATURED PROJECTS -->
  <section class="block" aria-labelledby="featured-h">
    <div class="section-inner">
      <div class="block-head">
        <div>
          <p class="eyebrow">Featured projects</p>
          <h2 id="featured-h" class="block-title">Shipped, running, and documented.</h2>
        </div>
        <a class="block-link" href="/projects/">All projects →</a>
      </div>
      <ul class="featured-grid">
        {
          featured.map((p) => (
            <li class="card proj-card">
              <div class="proj-head">
                <h3 class="proj-title">{p.title}</h3>
                <span class={`status status-${p.status.toLowerCase()}`}>{p.status}</span>
              </div>
              <p class="proj-dek">{p.dek}</p>
              <ul class="proj-stack" aria-label="Stack">
                {p.stack.map((s) => (
                  <li>{s}</li>
                ))}
              </ul>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 7. NEWSROOM PREVIEW -->
  <section class="block" aria-labelledby="news-h">
    <div class="section-inner">
      <div class="block-head">
        <div>
          <p class="eyebrow">Newsroom</p>
          <h2 id="news-h" class="block-title">Latest announcement</h2>
        </div>
        <a class="block-link" href="/newsroom/">Visit the Newsroom →</a>
      </div>
      <article class="card news-feature">
        <p class="news-meta">{latestNews.date} · {latestNews.kicker}</p>
        <h3 class="news-title"><a href={latestNews.href}>{latestNews.title}</a></h3>
        <p class="news-sum">{latestNews.summary}</p>
        <div class="news-links">
          <a href={latestNews.href}>Read the full release →</a>
          <a href="/newsroom/#media-kit">Media kit →</a>
        </div>
      </article>
    </div>
  </section>

  <!-- 8. FINAL CTA -->
  <section class="final-cta" aria-labelledby="cta-h">
    <div class="motif-bar" aria-hidden="true"></div>
    <div class="section-inner cta-inner">
      <h2 id="cta-h" class="cta-title">
        Building something with AI, or writing about someone who is?
      </h2>
      <p class="cta-sub">
        Reach out for interviews, speaking, partnerships, or just to compare notes on building
        with AI.
      </p>
      <div class="cta-row cta-row-center">
        <a class="btn btn-primary" href="mailto:hello@kenashe.ai">
          Get in touch
          <span aria-hidden="true">→</span>
        </a>
        <a class="btn btn-ghost" href="/newsroom/">Press &amp; media kit</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Shared layout */
  .section-inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .motif-bar {
    height: 5px;
    background: var(--grad);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal-blue);
    margin: 0 0 0.85rem;
  }

  /* Buttons */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .cta-row-center {
    justify-content: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.72rem 1.3rem;
    border-radius: 10px;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      transform 150ms ease,
      box-shadow 150ms ease,
      background-color 150ms ease,
      color 150ms ease,
      border-color 150ms ease;
  }
  .btn-primary {
    background: var(--grad);
    color: var(--surface);
    box-shadow: var(--shadow-sm);
  }
  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow);
    color: var(--surface);
  }
  .btn-ghost {
    background-color: var(--surface);
    color: var(--fg);
    border-color: var(--border);
  }
  .btn-ghost:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* 1. Hero */
  .hero {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(900px 420px at 88% -12%, color-mix(in oklab, var(--accent-2) 24%, transparent), transparent 60%),
      var(--surface);
    padding: 5.5rem 0 4.5rem;
  }
  .hero::after {
    content: '';
    position: absolute;
    right: -130px;
    bottom: -150px;
    width: 380px;
    height: 380px;
    background: var(--grad);
    opacity: 0.1;
    transform: rotate(18deg);
    border-radius: 56px;
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6.5vw, 4.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.02;
    color: var(--fg);
    margin: 0 0 1.25rem;
    max-width: 18ch;
  }
  .hero-sub {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.7vw, 1.3rem);
    line-height: 1.5;
    color: var(--muted);
    margin: 0 0 1.9rem;
    max-width: 40rem;
  }
  .trust {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--dark-blue);
    letter-spacing: 0.02em;
    margin: 1.75rem 0 0;
  }

  /* Generic content blocks */
  .block {
    padding: 4rem 0;
  }
  .block + .block {
    padding-top: 0;
  }
  .block-title {
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 3.2vw, 2.35rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--fg);
    margin: 0 0 2rem;
    max-width: 24ch;
  }
  .block-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .block-head .block-title {
    margin-bottom: 0;
  }
  .block-link {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    padding-bottom: 0.2rem;
  }
  .block-link:hover {
    color: var(--accent-2);
  }

  /* Cards (shared base) */
  .card {
    position: relative;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 46px 46px 0;
    border-color: transparent color-mix(in oklab, var(--accent-2) 22%, var(--surface)) transparent
      transparent;
  }

  /* 3. What I build */
  .pillars {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .pillar {
    padding: 1.5rem 1.4rem;
  }
  .pillar-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin: 0 0 0.55rem;
  }
  .pillar-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  /* 5. Featured projects */
  .featured-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
  }
  .proj-card {
    padding: 1.5rem 1.5rem 1.35rem;
  }
  .proj-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.85rem;
    margin-bottom: 0.6rem;
  }
  .proj-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.12;
    color: var(--fg);
    margin: 0;
  }
  .status {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.28rem 0.55rem;
    border-radius: 999px;
    border: 1px solid;
    white-space: nowrap;
  }
  .status-live {
    color: #0e7a37;
    background-color: #e6f6ec;
    border-color: #b7e3c6;
  }
  .status-shipped {
    color: var(--accent);
    background-color: #eaf1fd;
    border-color: #a9c6f5;
  }
  .proj-dek {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 1.1rem;
  }
  .proj-stack {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .proj-stack li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.24rem 0.5rem;
    font-variant-numeric: tabular-nums;
  }

  /* 2. Media credibility strip (navy band) */
  .media-strip {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(700px 320px at 92% -20%, rgba(87, 149, 245, 0.32), transparent 62%),
      #011338;
    padding: 4rem 0;
  }
  .eyebrow-light {
    color: #7fb0fb;
  }
  .media-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.12;
    color: var(--surface);
    margin: 0 0 1.6rem;
    max-width: 26ch;
  }
  .avail-list {
    list-style: none;
    margin: 0 0 2.25rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .avail-list li {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: #e7effc;
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(199, 218, 251, 0.28);
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
  }
  .topics-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #5795f5;
    margin: 0 0 0.7rem;
  }
  .topic-list {
    list-style: none;
    margin: 0 0 1.75rem;
    padding: 0;
    display: grid;
    gap: 0.45rem 1.5rem;
    grid-template-columns: 1fr;
  }
  .topic-list li {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: #c7dafb;
    padding-left: 1.1rem;
    position: relative;
  }
  .topic-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: #5795f5;
    font-weight: 700;
  }
  .media-cta a {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: #9cc1fb;
    text-decoration: none;
  }
  .media-cta a:hover {
    color: var(--surface);
  }
  @media (min-width: 680px) {
    .topic-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* 7. Newsroom preview */
  .news-feature {
    padding: 1.9rem 1.9rem 1.7rem;
  }
  .news-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin: 0 0 0.6rem;
  }
  .news-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.18;
    margin: 0 0 0.75rem;
    max-width: 46rem;
  }
  .news-title a {
    color: var(--fg);
    text-decoration: none;
  }
  .news-title a:hover {
    color: var(--accent);
  }
  .news-sum {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 1.25rem;
    max-width: 46rem;
  }
  .news-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 600;
  }
  .news-links a {
    color: var(--accent);
    text-decoration: none;
  }
  .news-links a:hover {
    color: var(--accent-2);
  }

  /* 8. Final CTA */
  .final-cta {
    margin-top: 1.5rem;
    background:
      radial-gradient(700px 300px at 50% -40%, color-mix(in oklab, var(--accent-2) 16%, transparent), transparent 60%),
      color-mix(in oklab, var(--accent-2) 8%, var(--bg));
  }
  .cta-inner {
    text-align: center;
    padding-top: 4.5rem;
    padding-bottom: 4.5rem;
    max-width: 46rem;
  }
  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.6vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.08;
    color: var(--fg);
    margin: 0 0 1rem;
  }
  .cta-sub {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 auto 1.9rem;
    max-width: 36rem;
  }
</style>
