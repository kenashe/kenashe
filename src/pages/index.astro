---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import FormattedDate from '../components/FormattedDate.astro';
import BuildCard from '../components/BuildCard.astro';
import { SITE_DESCRIPTION } from '../consts';
import { buildingCards } from '../data/building-cards';
import { personKenAshe } from '../data/schema';

// Blog: latest 5 posts, newest first.
const allNotes = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const notes = allNotes
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

// Building: latest 3 cards (same curated set as /building/).
const latestBuilds = buildingCards.slice(0, 3);

// Credibility cards (from About). "Digital marketer" lives here.
const hats = [
  {
    label: 'CPA',
    body: 'Evidence over vibes. A CPA reflex for numbers, controls, and proof, applied to every tool and workflow I adopt.',
  },
  {
    label: 'PMP / Operator',
    body: 'Most of my career in project management: scoping, sequencing, and actually shipping real deliverables on real timelines.',
  },
  {
    label: 'Digital marketer',
    body: 'A boutique marketing firm. Affiliate, SEO, and conversion across channels, with AI taking more of the lift each month.',
  },
  {
    label: 'AI builder',
    body: 'The application layer: agents, automations, AI-assisted websites, and workflow systems, built from existing models and tools.',
  },
];

const pillars = ['Agents', 'Automations', 'AI-assisted websites', 'Workflow systems'];

const models = ['Claude', 'ChatGPT', 'Gemini', 'Grok', 'DeepSeek'];
const tools = ['Claude Code', 'Codex', 'n8n', 'HyperAgent', 'Hermes', 'ElevenLabs', 'Higgsfield', 'OpenRouter'];

const credentials = [
  { name: 'Certified Public Accountant (CPA)', issuer: 'Active' },
  { name: 'Project Management Professional (PMP)', issuer: 'Active' },
  { name: 'AI Prototyping for Product Managers', issuer: 'Maven' },
  { name: 'How to Scale a Business With Agentic Workflows', issuer: 'Maven' },
  { name: 'OpenClaw & Claude Code program', issuer: 'AI Product Academy' },
];

const homeSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': 'https://kenashe.ai/#website',
      name: 'KenAshe.ai',
      url: 'https://kenashe.ai/',
      sameAs: ['https://www.linkedin.com/company/kenashe-ai'],
      description: 'Personal publication and public AI build log from Ken Ashe.',
      creator: { '@id': 'https://kenashe.ai/#ken-ashe' },
      publisher: { '@id': 'https://kenashe.ai/#ken-ashe' },
      mainEntity: { '@id': 'https://kenashe.ai/#ken-ashe' },
      inLanguage: 'en-US',
    },
    personKenAshe,
  ],
};
---

<BaseLayout description={SITE_DESCRIPTION}>
  <JsonLd slot="jsonld" data={homeSchema} />

  <article class="home">
    <header class="hero">
      <h1 class="hero-headline">Ken Ashe</h1>
      <p class="hero-lead">I build practical AI applications, and document the receipts in public.</p>
      <p class="hero-sub">
        Agents, automations, AI-assisted websites, and workflow systems, under my real name. No
        hype, no doom.
      </p>
      <div class="hero-ctas">
        <a class="cta cta-primary" href="/building/">
          See what I'm building
          <span aria-hidden="true">→</span>
        </a>
        <a class="cta cta-ghost" href="/blog/">Read the blog</a>
      </div>
    </header>

    <section aria-labelledby="bring-heading" class="block">
      <div class="block-head"><h2 id="bring-heading">What I bring</h2></div>
      <ul class="hats">
        {
          hats.map((h) => (
            <li class="hat">
              <h3 class="hat-label">{h.label}</h3>
              <p class="hat-body">{h.body}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="building-heading" class="block">
      <div class="block-head">
        <h2 id="building-heading">Building</h2>
        <a href="/building/" class="block-link">All builds →</a>
      </div>
      <ul class="receipts">
        {latestBuilds.map((p) => <BuildCard project={p} />)}
      </ul>
    </section>

    <section aria-labelledby="principles-heading" class="principles">
      <h2 id="principles-heading" class="sr-only">Principles</h2>
      <p class="principles-mark" aria-hidden="true">//</p>
      <p class="principle">No hype.</p>
      <p class="principle">No doom.</p>
      <p class="principle">Receipts only.</p>
    </section>

    <section aria-labelledby="work-heading" class="block">
      <div class="block-head"><h2 id="work-heading">How I work</h2></div>
      <p class="prose-p">
        I work at the AI application layer: turning existing models, APIs, coding tools, and
        automation platforms into useful systems. You don't need to train models or wire up
        infrastructure to make AI do real work. You need to use it well, and prove it.
      </p>
      <ul class="pillars" aria-label="What I build">
        {pillars.map((p) => <li>{p}</li>)}
      </ul>
      <p class="prose-p">
        This site is one of those projects, built end-to-end with Claude Code and reviewed by
        Codex, as a way to learn the stack in public. It's a sandbox and I treat it like one.
        Things break here; that's fine. What I learn feeds back into the real client work I do as a
        marketer.
      </p>
    </section>

    <section aria-labelledby="stack-heading" class="block">
      <div class="block-head"><h2 id="stack-heading">Stack</h2></div>
      <div class="stack-group">
        <p class="stack-label">Models</p>
        <ul class="stack" aria-label="Models">
          {models.map((s) => <li>{s}</li>)}
        </ul>
      </div>
      <div class="stack-group">
        <p class="stack-label">Tools &amp; platforms</p>
        <ul class="stack" aria-label="Tools and platforms">
          {tools.map((s) => <li>{s}</li>)}
        </ul>
      </div>
    </section>

    <section aria-labelledby="creds-heading" class="block">
      <div class="block-head"><h2 id="creds-heading">Credentials</h2></div>
      <ul class="creds">
        {
          credentials.map((c) => (
            <li class="cred">
              <span class="cred-name">{c.name}</span>
              <span class="cred-issuer">{c.issuer}</span>
            </li>
          ))
        }
        <li class="cred cred-pending">
          <span class="cred-name">Claude Certified Architect, Foundations</span>
          <span class="cred-issuer">Planned</span>
        </li>
      </ul>
    </section>

    <section aria-labelledby="blog-heading" class="block">
      <div class="block-head">
        <h2 id="blog-heading">Blog</h2>
        <a href="/blog/" class="block-link">All posts →</a>
      </div>
      <ul class="post-list">
        {
          notes.map((note) => (
            <li>
              <a href={`/blog/${note.id}/`}>
                <span class="post-title">
                  {note.data.draft && <span class="draft-tag">[Draft]</span>}
                  {note.data.title}
                </span>
                <span class="post-date">
                  <FormattedDate date={note.data.pubDate} format="short" />
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <p class="closing">
      Ken Ashe is an AI application builder, CPA, and PMP building with AI in public, and the
      founder of Lucky Domains, a domain acquisition, brokerage, and SEO services company.
    </p>
  </article>
</BaseLayout>

<style>
  .home {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 5rem 1.5rem 0;
  }

  /* Hero */
  .hero {
    margin-bottom: 5rem;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(3rem, 11vw, 7.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin: 0 0 1.5rem;
    color: var(--fg);
  }
  .hero-lead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.8vw, 1.375rem);
    line-height: 1.45;
    color: var(--fg);
    margin: 0 0 0.85rem;
    max-width: 38rem;
  }
  .hero-sub {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    line-height: 1.5;
    color: var(--muted);
    margin: 0 0 2.5rem;
    max-width: 40rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.7rem 1.15rem;
    border-radius: 4px;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      border-color 150ms ease;
  }
  .cta-primary {
    background-color: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
  }
  .cta-primary:hover {
    background-color: var(--fg);
    border-color: var(--fg);
    color: var(--bg);
  }
  .cta-ghost {
    background-color: transparent;
    color: var(--fg);
    border: 1px solid var(--border);
  }
  .cta-ghost:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Sections */
  .block {
    margin-top: 3.5rem;
  }
  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .block h2 {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .block-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted);
    text-decoration: none;
  }
  .block-link:hover {
    color: var(--fg);
  }

  /* What I bring */
  .hats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  .hat {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.4rem 1.4rem 1.25rem;
  }
  .hat-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }
  .hat-body {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--fg);
    margin: 0;
  }

  /* Build cards */
  .receipts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  /* How I work */
  .prose-p {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--fg);
    margin: 0 0 1.25rem;
    max-width: 40rem;
  }
  .prose-p:last-child {
    margin-bottom: 0;
  }
  .pillars {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .pillars li {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--fg);
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
  }

  /* Stack */
  .stack-group + .stack-group {
    margin-top: 1.1rem;
  }
  .stack-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 0.55rem;
  }
  .stack {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .stack li {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.3rem 0.6rem;
  }

  /* Credentials */
  .creds {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .cred {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .cred-name {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--fg);
  }
  .cred-issuer {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    flex-shrink: 0;
  }
  .cred-pending {
    opacity: 0.7;
  }
  .cred-pending .cred-name {
    color: var(--muted);
  }
  .cred-pending .cred-issuer {
    color: var(--accent);
    border: 1px dashed color-mix(in oklab, var(--accent) 45%, var(--border));
    border-radius: 999px;
    padding: 0.15rem 0.5rem;
  }

  /* Blog list */
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li {
    margin-bottom: 0.25rem;
  }
  .post-list a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    text-decoration: none;
    padding: 0.4rem 0;
  }
  .post-title {
    font-size: 1.0625rem;
    flex: 1;
  }
  .post-list a:hover .post-title {
    color: var(--accent);
  }
  .post-date {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .draft-tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-right: 0.4rem;
  }

  /* Principles */
  .principles {
    margin: 5rem 0 4rem;
    padding: 3.75rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .principles-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  .principle {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 7vw, 4.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: var(--fg);
    margin: 0;
  }
  .principle + .principle {
    margin-top: 0.3rem;
  }

  /* Closing boilerplate */
  .closing {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
    margin: 3.5rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    max-width: 42rem;
  }
</style>
