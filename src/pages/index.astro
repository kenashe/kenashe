---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { fetchLatestSubstackPosts } from '../utils/substack';
import {
  SITE_DESCRIPTION,
  SITE_URL,
  AUTHOR,
  NEWSLETTER_URL,
  SUBSTACK_RSS_URL,
  SOCIAL,
} from '../consts';

// Newsletter: real Substack posts at build time.
// - If the fetch succeeds, render real posts.
// - In dev, when the fetch returns nothing, render local placeholders so the
//   section has visual weight while iterating.
// - In prod, when the fetch returns nothing, render a single empty-state row.
//   We never ship placeholder copy to production.
const substackPosts = await fetchLatestSubstackPosts(SUBSTACK_RSS_URL, 3);
const newsletterPlaceholders: { title: string; href: string; date: string }[] = [
  { title: 'Placeholder newsletter post one', href: NEWSLETTER_URL, date: '2026' },
  { title: 'Placeholder newsletter post two', href: NEWSLETTER_URL, date: '2026' },
  { title: 'Placeholder newsletter post three', href: NEWSLETTER_URL, date: '2026' },
];

// AI Blog: pulled from the blog content collection, sorted by pubDate desc.
const allNotes = await getCollection('blog', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const notes = allNotes
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

type Project = {
  title: string;
  status: 'LIVE' | 'SHIPPED';
  dek: string;
  stack: string[];
  shippedAt: string;
  metric?: string;
};

// Days elapsed since an ISO date. Computed at build time — Vercel redeploys
// frequently enough (the blog pipeline ships daily) that drift stays small.
const daysSince = (iso: string) =>
  Math.max(0, Math.floor((Date.now() - new Date(iso).getTime()) / 86_400_000));

const projects: Project[] = [
  {
    title: 'AI blog automation',
    status: 'LIVE',
    dek: 'Autonomous pipeline that turns curated YouTube transcripts into auto-published working notes.',
    stack: ['n8n', 'Claude Opus 4.7', 'Gemini 3.1 Pro', 'GPT-5.5'],
    shippedAt: 'May 2026',
    metric: '40-point QA gate',
  },
  {
    title: 'kenashe.ai',
    status: 'LIVE',
    dek: 'This site. Built end-to-end with Claude Code, reviewed by Codex, shipped in a day.',
    stack: ['Astro', 'Tailwind', 'MDX', 'Vercel'],
    shippedAt: 'May 2026',
  },
  {
    title: 'Daily email to myself',
    status: 'LIVE',
    dek: 'Morning brief at 6 AM: weather, tickers, a dad joke, and 300 words on a rotating topic.',
    stack: ['Python', 'Claude API', 'Mac Mini'],
    shippedAt: 'May 2026',
    metric: `${daysSince('2026-05-04')} days running`,
  },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: AUTHOR,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  sameAs: SOCIAL.filter((s) => s.href.startsWith('http')).map((s) => s.href),
};
---

<BaseLayout description={SITE_DESCRIPTION}>
  <JsonLd slot="jsonld" data={personSchema} />

  <article class="home">
    <header class="hero">
      <h1 class="hero-headline">AI Optimist</h1>
      <p class="hero-positioning">
        An operator's case for building with AI. Proven in public. No hype, no doom.
      </p>
      <p class="hero-status">
        <span class="hero-status-prefix" aria-hidden="true">//&nbsp;</span>digital marketer ·
        CPA · building with AI in public
      </p>
      <div class="hero-ctas">
        <a class="cta cta-primary" href={NEWSLETTER_URL} target="_blank" rel="noopener">
          Subscribe
          <span aria-hidden="true">→</span>
        </a>
        <a class="cta cta-ghost" href="/blog/">Read the latest</a>
      </div>
    </header>

    <section aria-labelledby="building-heading" class="block">
      <div class="block-head">
        <h2 id="building-heading">Building</h2>
      </div>
      <ul class="receipts">
        {
          projects.map((p) => (
            <li class={`receipt receipt-${p.status.toLowerCase()}`}>
              <div class="receipt-head">
                <h3 class="receipt-title">{p.title}</h3>
                <span class={`badge badge-${p.status.toLowerCase()}`}>
                  <span class="badge-dot" aria-hidden="true" />
                  {p.status}
                </span>
              </div>
              <p class="receipt-dek">{p.dek}</p>
              <ul class="receipt-stack" aria-label="Stack">
                {p.stack.map((s) => (
                  <li>{s}</li>
                ))}
              </ul>
              <footer class="receipt-foot">
                <span class="receipt-meta">
                  <span class="receipt-meta-key">Shipped</span> {p.shippedAt}
                </span>
                {p.metric && (
                  <>
                    <span class="receipt-meta-sep" aria-hidden="true">
                      ·
                    </span>
                    <span class="receipt-meta">{p.metric}</span>
                  </>
                )}
              </footer>
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-labelledby="newsletter-heading" class="block">
      <div class="block-head">
        <h2 id="newsletter-heading">Newsletter</h2>
        <a href={NEWSLETTER_URL} class="block-link" target="_blank" rel="noopener">Subscribe →</a>
      </div>
      <ul class="post-list">
        {
          substackPosts.length > 0 ? (
            substackPosts.map((post) => (
              <li>
                <a href={post.link} target="_blank" rel="noopener">
                  <span class="post-title">{post.title}</span>
                  <span class="post-date">
                    <FormattedDate date={post.pubDate} format="short" />
                  </span>
                </a>
              </li>
            ))
          ) : import.meta.env.DEV ? (
            newsletterPlaceholders.map((post) => (
              <li>
                <a href={post.href} target="_blank" rel="noopener">
                  <span class="post-title">{post.title}</span>
                  <span class="post-date">{post.date}</span>
                </a>
              </li>
            ))
          ) : (
            <li class="newsletter-empty">
              <p class="post-placeholder">
                <span class="post-title">Latest newsletter posts will appear here.</span>
                <span class="post-date">—</span>
              </p>
            </li>
          )
        }
      </ul>
    </section>

    <section aria-labelledby="ai-blog-heading" class="block">
      <div class="block-head">
        <h2 id="ai-blog-heading">AI Blog</h2>
        <a href="/blog/" class="block-link">All posts →</a>
      </div>
      <ul class="post-list">
        {
          notes.length > 0 ? (
            notes.map((note) => (
              <li>
                <a href={`/blog/${note.id}/`}>
                  <span class="post-title">
                    {note.data.draft && <span class="draft-tag">[Draft]</span>}
                    {note.data.title}
                  </span>
                  <span class="post-date">
                    <FormattedDate date={note.data.pubDate} format="short" />
                  </span>
                </a>
              </li>
            ))
          ) : (
            <>
              <li>
                <span class="post-placeholder">
                  <span class="post-title">Note placeholder one</span>
                  <span class="post-date">—</span>
                </span>
              </li>
              <li>
                <span class="post-placeholder">
                  <span class="post-title">Note placeholder two</span>
                  <span class="post-date">—</span>
                </span>
              </li>
              <li>
                <span class="post-placeholder">
                  <span class="post-title">Note placeholder three</span>
                  <span class="post-date">—</span>
                </span>
              </li>
            </>
          )
        }
      </ul>
    </section>

    <section aria-labelledby="elsewhere-heading" class="block">
      <div class="block-head">
        <h2 id="elsewhere-heading">Elsewhere</h2>
      </div>
      <ul class="elsewhere-list">
        {
          SOCIAL.map((s) => (
            <li>
              <a href={s.href} rel={s.href.startsWith('http') ? 'me noopener' : undefined}>
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </article>
</BaseLayout>

<style>
  .home {
    max-width: 52rem;
    margin: 0 auto;
    padding: 5rem 1.5rem 0;
  }

  .hero {
    margin-bottom: 6rem;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(3rem, 11vw, 7.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    margin: 0 0 1.5rem;
    color: var(--fg);
  }
  .hero-positioning {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.8vw, 1.375rem);
    line-height: 1.45;
    color: var(--fg);
    margin: 0 0 1.5rem;
    max-width: 38rem;
  }
  .hero-status {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    letter-spacing: 0.02em;
    margin: 0 0 2.5rem;
  }
  .hero-status-prefix {
    color: var(--accent);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.7rem 1.15rem;
    border-radius: 4px;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      border-color 150ms ease;
  }
  .cta-primary {
    background-color: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
  }
  .cta-primary:hover {
    background-color: var(--fg);
    border-color: var(--fg);
    color: var(--bg);
  }
  .cta-ghost {
    background-color: transparent;
    color: var(--fg);
    border: 1px solid var(--border);
  }
  .cta-ghost:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .block {
    margin-top: 3.5rem;
  }
  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .block h2 {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .block-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted);
    text-decoration: none;
  }
  .block-link:hover {
    color: var(--fg);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-list li {
    margin-bottom: 0.25rem;
  }
  .post-list a,
  .post-placeholder {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    text-decoration: none;
    padding: 0.4rem 0;
  }
  .post-title {
    font-size: 1.0625rem;
    flex: 1;
  }
  .post-list a:hover .post-title {
    color: var(--accent);
  }
  .post-date {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .post-placeholder {
    color: var(--muted);
    cursor: default;
    margin: 0;
  }
  .draft-tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-right: 0.4rem;
  }

  .receipts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
  .receipt {
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.5rem 1.5rem 1.25rem;
    transition:
      border-color 200ms ease,
      transform 200ms ease;
  }
  .receipt:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .receipt-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.65rem;
  }
  .receipt-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.4vw, 1.625rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--fg);
    margin: 0;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.3rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    white-space: nowrap;
    background-color: var(--bg);
  }
  .badge-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background-color: currentColor;
  }
  .badge-live {
    color: var(--accent-2);
    border-color: color-mix(in oklab, var(--accent-2) 35%, var(--border));
  }
  .badge-live .badge-dot {
    background-color: var(--accent-2);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent-2) 18%, transparent);
  }
  .badge-shipped {
    color: var(--muted);
  }
  .receipt-dek {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--fg);
    margin: 0 0 1.25rem;
    max-width: 44rem;
  }
  .receipt-stack {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .receipt-stack li {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.25rem 0.55rem;
    font-variant-numeric: tabular-nums;
  }
  .receipt-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .receipt-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg);
    font-variant-numeric: tabular-nums;
  }
  .receipt-meta-key {
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-right: 0.4rem;
  }
  .receipt-meta-sep {
    color: var(--border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .elsewhere-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
  }
  .elsewhere-list a {
    color: var(--muted);
    text-decoration: none;
  }
  .elsewhere-list a:hover {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
</style>
