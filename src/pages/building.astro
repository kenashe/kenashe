---
import BaseLayout from '../layouts/BaseLayout.astro';
import BuildCard from '../components/BuildCard.astro';
import { buildingCards } from '../data/building-cards';

const description =
  'Everything Ken Ashe has shipped or runs live: AI agents, automations, and AI-assisted websites, built in public.';
---

<BaseLayout
  title="Building"
  description={description}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Building', path: '/building/' },
  ]}
>
  <div class="page">
    <header class="page-header">
      <p class="page-mark" aria-hidden="true">// building</p>
      <h1>Building</h1>
      <p class="tagline">
        Everything I've shipped or run live, newest first. Receipts only: it's all real and live.
      </p>
    </header>

    <ul class="receipts">
      {buildingCards.map((p) => <BuildCard project={p} />)}
    </ul>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .page-header {
    margin-bottom: 3rem;
  }
  .page-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0 0 1rem;
    color: var(--fg);
  }
  .tagline {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.45;
    color: var(--muted);
    margin: 0;
    max-width: 40rem;
  }
  .receipts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
</style>
