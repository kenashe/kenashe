---
import BaseLayout from '../layouts/BaseLayout.astro';
import BuildCard from '../components/BuildCard.astro';
import { projects } from '../data/builds';

const live = projects.filter((p) => p.status === 'LIVE');
const shipped = projects.filter((p) => p.status === 'SHIPPED');

const description = 'Every project Ken Ashe has shipped or is running live. Built with AI tools, in public.';
---

<BaseLayout title="Building" description={description}>
  <div class="page">
    <header class="page-header">
      <p class="page-mark" aria-hidden="true">// building</p>
      <h1>Building</h1>
      <p class="tagline">Everything shipped or running live.</p>
    </header>

    <section aria-labelledby="live-heading">
      <h2 id="live-heading" class="group-heading">Live</h2>
      <ul class="receipts">
        {live.map((p) => <BuildCard project={p} />)}
      </ul>
    </section>

    <section aria-labelledby="shipped-heading" class="group-shipped">
      <h2 id="shipped-heading" class="group-heading">Shipped</h2>
      <ul class="receipts">
        {shipped.map((p) => <BuildCard project={p} />)}
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 52rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 0;
  }
  .page-header {
    margin-bottom: 3rem;
  }
  .page-mark {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem;
  }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1;
    margin: 0 0 1rem;
    color: var(--fg);
  }
  .tagline {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.6vw, 1.25rem);
    line-height: 1.45;
    color: var(--muted);
    margin: 0;
  }
  .group-heading {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .group-shipped {
    margin-top: 3rem;
  }
  .receipts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
</style>
