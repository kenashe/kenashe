---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Ken Ashe.">
  <article class="page">
    <header class="page-header">
      <h1>Contact</h1>
      <p class="lede">
        Email is fastest. Otherwise, leave a note below and I'll get back to you.
      </p>
    </header>

    <form
      class="contact-form"
      method="post"
      action="/* TODO: wire to Formspree or serverless */"
      novalidate
    >
      <div class="field">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
      </div>

      <div class="field">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="6" required></textarea>
      </div>

      <button type="submit">Send</button>

      <p class="note">
        {/* TODO: remove this note once the form is wired */}
        This form is not wired up yet. Email me directly at{' '}
        <a href="mailto:hello@kenashe.ai">hello@kenashe.ai</a>.
      </p>
    </form>
  </article>
</BaseLayout>

<style>
  .page {
    max-width: 36rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 0;
  }
  .page-header {
    margin-bottom: 2.5rem;
  }
  .page-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }
  .lede {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--muted);
    font-size: 1.125rem;
    margin: 0;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-family: var(--font-sans);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  label {
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 500;
  }
  input,
  textarea {
    background: transparent;
    color: var(--fg);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 0.625rem 0.75rem;
    font: inherit;
    font-size: 0.9375rem;
    line-height: 1.5;
    width: 100%;
    transition: border-color 150ms ease;
  }
  input:focus,
  textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-color: transparent;
  }
  textarea {
    resize: vertical;
    min-height: 8rem;
    font-family: var(--font-serif);
  }

  button[type='submit'] {
    align-self: flex-start;
    background: var(--fg);
    color: var(--bg);
    border: 1px solid var(--fg);
    border-radius: 2px;
    padding: 0.625rem 1.25rem;
    font: inherit;
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 150ms ease;
  }
  button[type='submit']:hover {
    opacity: 0.85;
  }

  .note {
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 0.5rem 0 0;
    line-height: 1.5;
  }
  .note a {
    color: var(--muted);
  }
  .note a:hover {
    color: var(--fg);
  }
</style>
